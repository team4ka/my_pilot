e":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"68d64b97412e4c76c4540841","displayName":"Jan Küppers","imageUrl":"https://user-images.trustpilot.com/68d64b97412e4c76c4540841/73x73.png","numberOfReviews":1,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"67eee3b9786decdb9ef48154","filtered":false,"isPending":false,"text":"Ich habe den Artikel jetzt schon zum zweiten Mal bestellt und bin sehr zufrieden damit.","rating":5,"labels":{"merged":null,"verification":{"isVerified":true,"createdDateTime":"2025-04-03T21:38:33.000Z","reviewSourceName":"WooCommerce","verificationSource":"invitation","verificationLevel":"verified","hasDachExclusion":false}},"title":"Ein Produkt, was sich lohnt zu probieren ","likes":0,"source":"WooCommerce","dates":{"experiencedDate":"2025-03-20T00:00:00.000Z","publishedDate":"2025-04-03T21:38:33.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"5ea8124c842631bb971fa0f3","displayName":"Sven Fischer","imageUrl":"","numberOfReviews":13,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":2,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"67f36dea73e2fb35d0164bb3","filtered":false,"isPending":false,"text":"Lieferung schnell und gut. Ware überrascht mich positiv und der Preis auch! Das war die erste Bestellung, aber nicht die Letzte!!! Perfekt, danke ;-)","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-04-07T08:17:14.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Qualität","likes":0,"source":"Organic","dates":{"experiencedDate":"2025-04-07T00:00:00.000Z","publishedDate":"2025-04-07T08:17:14.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"53c90f5200006400017f99ea","displayName":"Lothar Schmalbach","imageUrl":"","numberOfReviews":6,"countryCode":"DE","hasImage":false,"isVerified":true},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"69087dd695eadb340ac3062a","filtered":false,"isPending":false,"text":"Hallo. \n\nIch habe etwas auf der Website bestellt (Sirup) und darauf mehrere Tage gewartet, als es laut DPD endlich abgeholt wurde, stand dort plötzlich, dass das Paket nicht zugestellt werden konnte und dass das Paket zurück an den Absender geschickt wird. \nWeder war DPD bei mir, noch krieg man irgendeine Info vom Spliffstore. Ich habe im vorausbezahlt und kriege weder online, noch anderswo Informationen.\nPaket kommt nicht und Geld ist weg. \nFür mich sind die Bewertung hier alle Fake und der Shop Scam. \nNie wieder werd ich bei den bestellen, da kann ich das Geld auch anzünden. ","rating":1,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-11-03T12:03:02.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Lieferung kommt nicht an","likes":1,"source":"Organic","dates":{"experiencedDate":"2025-11-01T00:00:00.000Z","publishedDate":"2025-11-03T12:03:02.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"5fd220f033b62e0019430cae","displayName":"Rapfanatik Ultra","imageUrl":"","numberOfReviews":6,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":{"message":"Guten Tag,\n\nwir bedauern diese schlechte Erfahrung sehr und verstehen Ihre Unzufriedenheit.\n\nEs kam insbesondere bei unseren Sendungen mit dem Postdienst DPD zu Lieferproblemen. Aus diesem Grund haben wir unseren Logistikpartner gewechselt, um die Zuverlässigkeit und Qualität unseres Services zu verbessern. Unsere ersten Eindrücke von den jüngsten Sendungen sind ausgezeichnet. \n\nSeien Sie versichert, dass unser Kundenservice Ihnen gerne zur Verfügung steht, um die Situation zu klären. Zögern Sie nicht, uns unter Angabe Ihrer Bestellnummer zu kontaktieren.\n\nDas Team von Spliffstore","publishedDate":"2026-01-29T13:02:13.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"68b202675e8f48a1a945c12b","filtered":false,"isPending":false,"text":"Ich fande das high sehr gut und lange anhaltend. Leider ist der Geschmack des Sirups sehr bitter im Nachgeschmack, was allerdings auch nicht so schlimm ist da Mann sie ja kein Liter davon macht. ","rating":4,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-08-29T21:41:27.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Ich fande das high gut und langanhaltend ","likes":0,"source":"Organic","dates":{"experiencedDate":"2025-08-17T00:00:00.000Z","publishedDate":"2025-08-29T21:41:27.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"68b2021504313e5f636a2f8b","displayName":"Jerome","imageUrl":"","numberOfReviews":1,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"67efd9024f8edc978263a8cd","filtered":false,"isPending":false,"text":"Perfekte Lieferung Super Produkt. Und verdammt schnell!!!","rating":5,"labels":{"merged":null,"verification":{"isVerified":true,"createdDateTime":"2025-04-04T15:05:06.000Z","reviewSourceName":"WooCommerce","verificationSource":"invitation","verificationLevel":"verified","hasDachExclusion":false}},"title":"Perfekte Lieferung Super Produkt","likes":0,"source":"WooCommerce","dates":{"experiencedDate":"2025-03-21T00:00:00.000Z","publishedDate":"2025-04-04T15:05:06.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"67efd90089ee144030560126","displayName":"Thomas Littkemann","imageUrl":"","numberOfReviews":1,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"67d60a6742dff955d5c266db","filtered":false,"isPending":false,"text":"hey ho.\n\nschneller und sehr netter service. zudem eine gute qualität. ich gebe euch eine 5,5 von 5 🙃","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-03-16T01:16:55.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"hey ho.","likes":0,"source":"Organic","dates":{"experiencedDate":"2025-03-16T00:00:00.000Z","publishedDate":"2025-03-16T01:16:55.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"66e49152fb6f8705511fd41e","displayName":"Tim Lerner","imageUrl":"https://user-images.trustpilot.com/66e49152fb6f8705511fd41e/73x73.png","numberOfReviews":6,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":2,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"67f7b4b308c2244667ec1671","filtered":false,"isPending":false,"text":"Moin, ich habe Haschisch bestellt und bekam irgendwas was so aussehen sollte, aber selbst das \nhat nicht geklappt. Als Weltreisender habe ich gutes\nviel gutes Haschisch gesehen und konsumiert, das hier\nist lächerlich! Zum Glück ist bei uns legalisiert und ich auf so einen Müll nicht angewiesen. Hatte trotzdem neugierig bestellt und war extrem enttäuscht.","rating":1,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-04-10T14:08:19.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Moin, ","likes":1,"source":"Organic","dates":{"experiencedDate":"2025-04-10T00:00:00.000Z","publishedDate":"2025-04-10T14:08:19.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"657869e8daa9ba0012e8612b","displayName":"Niemann","imageUrl":"","numberOfReviews":6,"countryCode":"DE","hasImage":false,"isVerified":true},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"693feb8e25fa62e56647e73e","filtered":false,"isPending":false,"text":"Meine lezter Bestellung war nicht gut, habe keine Wirkung gemerkt, bin sehr enttäuscht.  Bestellung von 5 Dezember.  Habe aus Versehen noch 2 mal bestellt,  jetzt sitz ich da mit sch das nicht wirken, habe sogar als Tee getrunken,  auch keine Wirkung und schmecked eklig.  LG KATHLEEN ","rating":1,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-12-15T13:05:51.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Meine lezter Bestellung war nicht gut","likes":1,"source":"Organic","dates":{"experiencedDate":"2025-12-15T00:00:00.000Z","publishedDate":"2025-12-15T13:05:51.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"693feb853d98f013f1f98513","displayName":"Kathleen Kaeuffert","imageUrl":"https://user-images.trustpilot.com/693feb853d98f013f1f98513/73x73.png","numberOfReviews":1,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":{"message":"Hallo Kathleen,\nvielen Dank, dass Sie sich die Zeit genommen haben, Ihre Erfahrungen mit uns zu teilen. Es tut uns aufrichtig leid, dass Ihre Bestellung vom 5. Dezember nicht Ihren Erwartungen entsprochen hat und Sie nicht die gewünschten Ergebnisse erzielt haben.\n\nJeder Mensch kann unterschiedlich auf unsere Produkte reagieren, da mehrere Faktoren ihre Wirksamkeit beeinflussen können (Anwendungsweise, Dauer, Dosierung usw.). \nIch möchte Sie auch darauf hinweisen, dass es notwendig ist, Ihrer Zubereitung ein Fett (Milch, Öl...) hinzuzufügen, da Cannabinoide sich nicht in Wasser auflösen. Es ist daher normal, dass Sie durch den alleinigen Aufguss der Blüten keine Wirkung spüren.  \nAußerdem möchte ich daran erinnern, dass CBD in erster Linie eine entspannende und keine psychoaktive Wirkung hat. Wenn Sie eine stärkere Alternative bevorzugen, empfehlen wir Ihnen unsere THCX-Produktreihe.\nUnser Team steht unseren Kunden jederzeit zur Verfügung, um sie zu begleiten und bestmöglich zu beraten.\n\nWir haben auch festgestellt, dass Sie kürzlich eine weitere Bestellung aufgegeben haben, wofür wir uns herzlich bedanken. Wir hoffen, dass Sie mit dieser neuen Erfahrung voll und ganz zufrieden sein werden.\n\nZögern Sie nicht, unseren Kundenservice zu kontaktieren, um eine auf Ihr Profil zugeschnittene Beratung zu erhalten.\nWir stehen Ihnen jederzeit zur Verfügung und wünschen Ihnen einen schönen Tag.\n\nDas Spliff-Team","publishedDate":"2026-01-22T16:12:00.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null}],"topicAiSummaryReviews":[["65a8f486fe59a0421a2a19f2_de_product",[{"id":"698446f9ec4aefc02f477d6c","filtered":false,"isPending":false,"text":"Habe weitere Produckte getestet und kann nur Sagen Wow macht weiter so schnelle lieferung Top service und ein großer Dank geht an Clara die immer erreichbar ist bei allen fragen","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2026-02-05T09:30:01.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Habe weitere Produckte getestet und…","likes":0,"source":"Organic","dates":{"experiencedDate":"2026-02-05T00:00:00.000Z","publishedDate":"2026-02-05T09:30:01.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"6959697431cbb9360b883530","displayName":"Enrico Mirek Willing","imageUrl":"https://user-images.trustpilot.com/6959697431cbb9360b883530/73x73.png","numberOfReviews":5,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":{"message":"Vielen herzlichen Dank für Ihr großartiges Feedback! ✨\n\nWir freuen uns sehr, dass Ihre Erfahrung Ihren Erwartungen entsprochen hat.\n\nEin großes Dankeschön auch für Ihre besondere Erwähnung von Clara: Wir werden ihr Ihre Nachricht selbstverständlich weiterleiten – sie wird sich sehr über Ihre Worte freuen.\n\nWir freuen uns darauf, Sie bald wieder bedienen zu dürfen! 💚\n\nDas Spliff-Team","publishedDate":"2026-02-18T09:01:19.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":2,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"696dda065fd8b422f79ff350","filtered":false,"isPending":false,"text":"Spliff ist genial. Ich bin sehr glücklich, dieses aus Zufall im Internet gefunden zu haben. Extrem zuverlässig :-) Clara kommuniziert immer sehr freundlich, kompetent und zeitnah. Gute Qualität, super Verpackung. Diskret. Gesund. Hilft bei körperlichen Schmerzen .Ein tolles Team - Danke :-)","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2026-01-19T09:15:18.000Z","reviewSourceName":"BasicLink","verificationSource":"invitation","verificationLevel":"invited","hasDachExclusion":false}},"title":"Spliff ist genial","likes":0,"source":"BasicLink","dates":{"experiencedDate":"2026-01-14T00:00:00.000Z","publishedDate":"2026-01-19T09:15:18.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"696dd9f84698843c3f69486a","displayName":"Colette Von Der Goltz-Koydl","imageUrl":"https://user-images.trustpilot.com/696dd9f84698843c3f69486a/73x73.png","numberOfReviews":1,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":{"message":"Vielen Dank für dieses großartige Feedback!\nWir freuen uns sehr, dass Sie Spliff entdeckt haben und dass unsere Produkte und unsere Betreuung Ihren Erwartungen entsprochen haben.\nDas gesamte Team, insbesondere Clara, bedankt sich für Ihre sehr ermutigenden Worte.\nWir freuen uns darauf, Sie wieder zu begleiten 🌿","publishedDate":"2026-01-22T16:02:02.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"695fc5cc1f25bd7787e15f5a","filtered":false,"isPending":false,"text":"Habe schon öfter dort den Sirup bestellt, der mir bei meinen Depressionen abends zum Abspannen hilft. Da ich kein Weed mehr rauche bzw. generell nicht mehr rauche, kommt der Sirup als Alternative gut daher. Bei meiner letzten Bestellung kam es dank DHL zu Lieferproblemen, der Support von Spliff war in dem Fall sehr schnell und Kundenorientiert und hilfsbereit.Gibt eigentlich nichts zu bemängeln, Ware sowie Service Top ;-)","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2026-01-08T16:57:16.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Habe schon öfter dort den Sirup…","likes":0,"source":"Organic","dates":{"experiencedDate":"2026-01-08T00:00:00.000Z","publishedDate":"2026-01-08T16:57:16.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"6608108717cfe20012d1b2b3","displayName":"C.Husemann","imageUrl":"","numberOfReviews":6,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":{"message":"Vielen Dank für Ihr positives Feedback und Ihre Treue 😊\nWir freuen uns, dass Sie mit dem Magic Potion zufrieden sind und dass er für Sie eine gute Alternative darstellt.\nTrotz der Lieferprobleme, die außerhalb unserer Kontrolle lagen, sind wir froh, Ihnen schnell helfen zu können.\nBis bald und vielen Dank für Ihr Vertrauen!\n\nDas Spliff-Team","publishedDate":"2026-01-22T15:41:12.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"69517d572b742c1f50b84dfc","filtered":false,"isPending":false,"text":"Ich habe viel erlebt mit „Clara“.  Ich habe immer Antwort bekommen, meistens nach einem Tag aber auch zwei und auch schon längere Zeit aber es hat sich immer jemand gemeldet, um mir und meiner Bestellung zu helfen. Manche schreiben hier, die Gummibärchen würden nicht knallen, finde ich auch leider, bei jeder meiner Bestellungen ist immer son Gummibärchen dabei, würde ich niemals bestellen, haben null Effekt.. Was ich immer bestelle ist dieser Sirum 300 in verschiedenen Geschmacksrichtungen, wobei der bittere Nachgang bei jedem Schluck schon echt bitter ist. Der Situp knallt gut, bin eigentlich leidenschaftliche kifferin, habe aber mit rauchen aufgehört. Ich bin im Training.wie man so schön sagt.. trotzdem knallt der Sirup sehr gut, ich finde nur irgendwie leider nicht so lange so 3 Stunden aber das mag an der EU und deren Bevormundung und der runter Regulierung liegen.","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-12-28T20:56:23.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Ich habe viel erlebt mit „Clara“","likes":0,"source":"Organic","dates":{"experiencedDate":"2025-12-28T00:00:00.000Z","publishedDate":"2025-12-28T20:56:23.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"61e82b58317986001258fdec","displayName":"Itz_akari-Chan UWU","imageUrl":"","numberOfReviews":5,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":{"message":"Guten Tag,\nvielen Dank für Ihr ausführliches Feedback und Ihre positiven Worte zu Ihrem Austausch mit unserem Service – die Qualität unseres Kundenservices ist für uns von zentraler Bedeutung.\nBezüglich der Gummies haben wir eine Charge identifiziert, die in Bezug auf die Wirkung nicht unseren Erwartungen entsprach. Dieses Problem wurde inzwischen behoben, und die aktuellen Chargen entsprechen wieder vollständig unseren Standards.\nEs freut uns sehr, dass Ihnen die Sirupe gefallen. Der leicht bittere Geschmack ist auf die hohe THC-Konzentration zurückzuführen. Die kürzere Wirkungsdauer erklärt sich durch die schnelle Aufnahme aufgrund der Verdauung und der flüssigen Produktform.\nWenn Sie eine länger anhaltende Wirkung suchen, empfehlen wir Ihnen, unsere Brownies zu probieren, deren langsamere Aufnahme in der Regel eine Wirkungsdauer von 4 bis 5 Stunden ermöglicht.\nVielen Dank nochmals für Ihr Vertrauen.\n\nIhr Spliff-Team","publishedDate":"2026-01-15T14:50:54.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"691f29b6b97d424267af52ad","filtered":false,"isPending":false,"text":"Erstens sind alle Produkte von Spliff wirklich gut. Zweitens hatte ich eine Reklamation zur einem der Vapes und Pods und habe sofort ganz unkompliziert Ersatz zugeschickt bekommen. Das freut mich sehr, weil die Dinger wirklich klasse sind! Aber vorsichtig anfangen, da steckt wirklich power hinter! Danke!","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-11-20T16:46:14.000Z","reviewSourceName":"BasicLink","verificationSource":"invitation","verificationLevel":"invited","hasDachExclusion":false}},"title":"Super Vapes, toller Service, gerne wieder!","likes":0,"source":"BasicLink","dates":{"experiencedDate":"2025-11-20T00:00:00.000Z","publishedDate":"2025-11-20T16:46:14.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"6345387007d7b20014c284f4","displayName":"Kunde HH Eidelstedt","imageUrl":"","numberOfReviews":9,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":{"message":"Hallo,\nvielen Dank für Ihr begeistertes Feedback! Wir freuen uns sehr, dass Ihnen unsere Vapes und unser Service gefallen haben. Sie haben Recht: Der Magic Vape mit der höchsten THCX-Konzentration in unserem Sortiment ist eine ausgezeichnete Wahl für erfahrene Konsumenten.\nGute Nachrichten: In den nächsten Wochen werden neue Geschmacksrichtungen erhältlich sein. Wir hoffen, dass sie Ihnen gefallen werden!\n\nDas Spliff-Team","publishedDate":"2026-01-22T15:42:15.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"68c0434030a357154bb1ff5a","filtered":false,"isPending":false,"text":"Nehme unter ärztlicher Aufsicht und Empfehlung eine Kombi von 2 Medikamente und CBD und THC. Brauche 5X täglich 5 mg THC.\nGummibärchen sind Ideal teilbar und vor allem auf reisen wertvoll. Ich möchte keine Blüten mit über die Landesgrenzen bringen und Ärger bekommen.\nGummibärchen sind Ideal. Aber ich möchte mir nicht ausmalen was passiert wenn man ein ganzes Teil auf einmal isst.\nschneller Versand\nvon meiner Seite volle Empfehlung ","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-09-09T17:09:52.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Gummibärchen der besonderen Art ","likes":0,"source":"Organic","dates":{"experiencedDate":"2025-09-08T00:00:00.000Z","publishedDate":"2025-09-09T17:09:52.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"597869100000ff000ab3c38e","displayName":"Günter V.","imageUrl":"","numberOfReviews":10,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"68b0226176b98335e774fcb5","filtered":false,"isPending":false,"text":"Habe dort vor einem Jahre etwas bestellt. Und keine Ware erhalten.Nach mehrmaligem schreiben an die Firma. Konnte sie mir trotz Vorauszahlungen nicht weiter helfen!!! Ich weiß  nicht warum so viele positive Bewertungen dabei sind??? Kann ich 0 nachvollziehen... . Definitiv und zu 1000% werde ich nie wieder dort bestellen und niemanden empfehlen!!! ","rating":1,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-08-28T11:33:21.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Habe dort vor einem Jahre etwas…","likes":1,"source":"Organic","dates":{"experiencedDate":"2025-08-27T00:00:00.000Z","publishedDate":"2025-08-28T11:33:21.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"68ae0c1b960069ceb813645f","displayName":"Ten ten Bibi","imageUrl":"https://user-images.trustpilot.com/68ae0c1b960069ceb813645f/73x73.png","numberOfReviews":4,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"687f829ce96d48123652df13","filtered":false,"isPending":false,"text":"Hallihallo, diesmal probierten mein Mann und ich das trinkbare MAGIC POTION aus, was absolut empfehlenswert ist...\nEs wirkt entspannend und beruhigend, man wird schnell schläfrig und fühlt sich \"Pudelwohl\"!\n...wir raten zu einem Geschmacksstarkem Mischgetränk denn PUR ist es wirklich BITTER!","rating":4,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-07-22T14:22:52.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Wie auf Wolke 7","likes":0,"source":"Organic","dates":{"experiencedDate":"2025-07-04T00:00:00.000Z","publishedDate":"2025-07-22T14:22:52.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"687f826004313e0b66322083","displayName":"Melanie","imageUrl":"","numberOfReviews":1,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"687b5fdfb06c5221012544aa","filtered":false,"isPending":false,"text":"Ich bin jetzt schon seit einem halben Jahr Kunde und kann das ganze daher recht gut einschätzen: Spliff ist für uns Europäer, solange man Cannabis nicht als normaler Bürger in öffentlichen Shops beziehen kann, wohl die beste Alternative.\n\nDie Edibles hauen dich kompletto weg, besonders der 300mg Sirup, danach kommst du gar nicht mehr klar, das hatte ich so auch noch nicht gesehen. Leute die schreiben, das wäre ohne Wirkung oder wäre Betrug, erzählen einfach Misst.\n\nDie THC Alternative \"THCX\" ist sehr angenehm zum Rauchen und man merkt einfach, das das kein Dreck von der Straße ist. Man kann nur nicht erwarten, dass es dich so wegghaut wie manch anderes was wir hier haben, aber dafür ist es gut gezüchtet und sehr angenehm.\n\nMein Lieferung kam bisher nie zu spät, auch wenn es immer circa 1 Woche dauert, weil es aus Süd Frankreich kommt.\n\nIch bin sehr zufrieden, auch wenn natürlich das THCX Gras gerne noch etwas mehr ballern kann.","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-07-19T11:05:35.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Stammkunde und kann es nur empfehlen ","likes":0,"source":"Organic","dates":{"experiencedDate":"2025-07-19T00:00:00.000Z","publishedDate":"2025-07-19T11:05:35.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"687b5fda192bd34730c89328","displayName":"Maximilian","imageUrl":"https://user-images.trustpilot.com/687b5fda192bd34730c89328/73x73.png","numberOfReviews":1,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"687787ee0ceaf86e9cb6b55f","filtered":false,"isPending":false,"text":"Schnelle Lieferung! \nIch hatte erst kürzlich Liederprobleme, aber das LAG NICHT an dem tollen Spliff-Team!\nEs lag an meinem deutschen Logistiker DHL!\nOhne Rückmeldung weshalb der lieferstatus seit 5 Tagen nicht aktualisiert wurde, habe ich an Tag 6 meine Ware endlich abholen dürfen!\nDas Spliff-Team hat derweil zügig Hilfe angeboten aber auch zum Zeitpunkt der Rückmeldung es fragwürdig gefunden, dass die Lieferung pünktlich versendet und doch so lange brauchte, um in einer Packstation zu landen.\n\nDanke Spliff-Team!\nSuper Marke übrigens Magic Candy Sirup 🥳","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-07-16T13:07:26.000Z","reviewSourceName":"BasicLink","verificationSource":"invitation","verificationLevel":"invited","hasDachExclusion":false}},"title":"Schnelle Lieferung","likes":0,"source":"BasicLink","dates":{"experiencedDate":"2025-07-15T00:00:00.000Z","publishedDate":"2025-07-16T13:07:26.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"687787e520554d35213db51e","displayName":"bella n","imageUrl":"https://user-images.trustpilot.com/687787e520554d35213db51e/73x73.png","numberOfReviews":1,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"686655e085810f38251ea231","filtered":false,"isPending":false,"text":"Ich hab mich an den Support gewendet, per E-Mail, keine 1,5 Stunden später hatte ich eine Antwort, das Spliff nicht antwortet ist ein übles \"Schreckgespenst\". Auf erneute Frage, hatte ich noch schneller eine Antwort, ca. 1 Stunde. Ich war freundlich, das Spliff Team war auch sehr freundlich, erklärte mir wo es hängen könnte, denn ab der Post, selbst auf dem Jupiter, muss Spliff bei der \"Post\" nachfragen und kann dann wieder informieren. Müsste man verstehen können.\nGrüße an das Spliff- Team, ich bin begeistert. \nZur Sendung, da gehören dafür 5 Sterne hintendran, kauf ich auf jeden Fall wieder ein, wenn es kurz hakt, cool bleiben ;) \nTHX SPLIFF  ","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-07-03T12:05:20.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Schnellster Support ever","likes":0,"source":"Organic","dates":{"experiencedDate":"2025-07-03T00:00:00.000Z","publishedDate":"2025-07-03T12:05:20.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"686650212f24784db336b638","displayName":"Oliver Jünger","imageUrl":"https://user-images.trustpilot.com/686650212f24784db336b638/73x73.png","numberOfReviews":4,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":3,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"68285f1933dc54410b39c1cb","filtered":false,"isPending":false,"text":"Die Kommunikation mit spliff ist hervorragend. Und das gelieferte Material ist genau wie beschrieben. Die THCX-produkte sind der Knaller. Der rote Libanon, 2 Züge und ich war auf Wolke 7. Immer wieder gern","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-05-17T12:04:09.000Z","reviewSourceName":"BasicLink","verificationSource":"invitation","verificationLevel":"invited","hasDachExclusion":false}},"title":"Ultrageil","likes":0,"source":"BasicLink","dates":{"experiencedDate":"2025-05-15T00:00:00.000Z","publishedDate":"2025-05-17T12:04:09.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"6825f930bf768bd7fdfd2616","displayName":"Joachim Schaler","imageUrl":"https://user-images.trustpilot.com/6825f930bf768bd7fdfd2616/73x73.png","numberOfReviews":2,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":2,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"6825faed407f1555597d0e24","filtered":false,"isPending":false,"text":"Das hat ja reibungslos geklappt. Kommunikation super. Rezessionen anderer Kunden erfüllten mich mit Sorgen um mein Geld. Der rote Libanon so lecker und knallig. Gott muss ein libanese  sein 😂","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-05-15T16:32:13.000Z","reviewSourceName":"BasicLink","verificationSource":"invitation","verificationLevel":"invited","hasDachExclusion":false}},"title":"Alles prima schnelle lieferung immer wieder gern ","likes":0,"source":"BasicLink","dates":{"experiencedDate":"2025-05-15T00:00:00.000Z","publishedDate":"2025-05-15T16:32:13.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"6825f930bf768bd7fdfd2616","displayName":"Joachim Schaler","imageUrl":"https://user-images.trustpilot.com/6825f930bf768bd7fdfd2616/73x73.png","numberOfReviews":2,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":2,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"681315d0a4a75bced57191b7","filtered":false,"isPending":false,"text":"Ergänzung des ursprünglichen Textes: Nachdem Spliff zunächst nicht reagieert hatte, wurde in der Zwischenzeit eine umfangreiche Suche gestartet. Leider lässt sich der Standort der Sendung nicht mehr bestimmen, auch, weil zwei Transportdienstleister involviert sind. Heute hat mir Spliff die erneute Sendung oder vollständige Rückerstattung meiner Auslagen angeboten. Das nenne ich praktizierte Kundenorientierung. Deswegen Heraufstufung auf vier Sterne. Ursprünglicher Text v. 30.04.25: \"Eigentlich null Sterne. Ich habe Anfang April was bestellt. Als die Zahlung anfangs nicht korrekt war (zu wenig, weil ich ein Bonusangebot genutzt habe) wurde ich sofort von einer deutsch sprechenden Mitarbeiterin angerufen.\nSeitdem warte ich auf die Postsendung. Habe die Firma Spliff mehrfach angemailt, habe auch zweimal auf den AB dort gesprochen. Reaktion bisher: keine. Wenn die Kohle dort ist, scheint die Sache für die Firma erledigt zu sein, dann sind Kontaktversuche offenbar lästig und es wird nicht reagiert. Unterirdischer \"Service\", JAMAIS PLUS\"  ","rating":4,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-05-01T08:33:52.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Eigentlich null Sterne - korrigiert auf vier Sterne","likes":0,"source":"Organic","dates":{"experiencedDate":"2025-04-30T00:00:00.000Z","publishedDate":"2025-05-01T08:33:52.000Z","updatedDate":"2025-06-12T09:12:24.000Z","submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"52510d2000006400014f3916","displayName":"Rainer Gottlieb","imageUrl":"","numberOfReviews":1,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"67ebc1724001207f69569dd5","filtered":false,"isPending":false,"text":"Ich hatte Gummibärchen bestellt, da ich nicht rauche. Ich bekam auch Gummibärchen. Allerdings viel weniger als gedacht. Stattdessen war ein fertiger Joint dabei, den ich nicht bestellt hatte und auch nicht benutzen kann, da ich ja -wie gesagt-nicht rauche. Schade.","rating":4,"labels":{"merged":null,"verification":{"isVerified":true,"createdDateTime":"2025-04-01T12:35:30.000Z","reviewSourceName":"WooCommerce","verificationSource":"invitation","verificationLevel":"verified","hasDachExclusion":false}},"title":"Ich hatte Gummibärchen bestellt","likes":0,"source":"WooCommerce","dates":{"experiencedDate":"2025-03-18T00:00:00.000Z","publishedDate":"2025-04-01T12:35:30.000Z","updatedDate":"2025-04-01T13:24:23.000Z","submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"6557c1d0d48df20012a8ede7","displayName":"Fielz","imageUrl":"","numberOfReviews":3,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"67e5c75f22e38694c45c92e8","filtered":false,"isPending":false,"text":"Ich habe mich mal an den Sirup ran gemacht und probiert ,nach der Einnahme des Produktes kam nach 40 min. leicht die Wirkung ( angenehm und entspannt) ungefähr nach 70 min. wurde die Wirkung stärker und ich war in einer ganz anderen Galaxie, ich habe mir die Kopfhörer aufgesetzt und ska Musik angehört das war ein sehr schönes Gefühl (die Rakete ist absolut abgehoben) nach 5,5 Stunden ist die Wirkung abgeklungen (top und völlig ausreichend) der Geschmack war nicht so meins und vor allem nicht auf das Brötchen, das schmeckt nicht, ansonsten  war ich sehr zufrieden mit dem Produkt ","rating":5,"labels":{"merged":null,"verification":{"isVerified":true,"createdDateTime":"2025-03-27T23:47:11.000Z","reviewSourceName":"WooCommerce","verificationSource":"invitation","verificationLevel":"verified","hasDachExclusion":false}},"title":"Ich habe mich mal an den Sirup ran…","likes":0,"source":"WooCommerce","dates":{"experiencedDate":"2025-03-13T00:00:00.000Z","publishedDate":"2025-03-27T23:47:11.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"67e5c75e89ee14655d4b8896","displayName":"Maik Trumpf","imageUrl":"","numberOfReviews":1,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"67d7f080d32e7a0a94ff86cb","filtered":false,"isPending":false,"text":"Richtig gut. Je nach Dosis (1/4 - 1/2 - 3/4 oder ein ganzes Bärchen) alles dabei von einfach nur relaxed bis mehr als chillig zu klar und super angenehm breit. Klare Kaufempfehlung. Viel besser zu dosieren als rauchen und ein ganz anderes, viel bewussterer und klarer Zustand. Bestellen definitiv wieder. Ablauf war gut, Lieferung aus FR auch akzeptabel was die Zeit angeht.","rating":5,"labels":{"merged":null,"verification":{"isVerified":true,"createdDateTime":"2025-03-17T11:50:56.000Z","reviewSourceName":"WooCommerce","verificationSource":"invitation","verificationLevel":"verified","hasDachExclusion":false}},"title":"Klare Empfehlung","likes":0,"source":"WooCommerce","dates":{"experiencedDate":"2025-03-16T00:00:00.000Z","publishedDate":"2025-03-17T11:50:56.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"67d7f07f7062e8cc0ed5965b","displayName":"J. E.","imageUrl":"","numberOfReviews":1,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null}]],["65a8f486fe59a0421a2a19f2_de_quality",[{"id":"697c892e1c2d2768305dac3d","filtered":false,"isPending":false,"text":"Seit Mai 2025 bestelle ich jeden Monat bei Spliff. Die Qualität ist der Hammer und immer exakt gleich gut. Das Produkt kommt in edlen schwarzen Tüten die luftdicht verschweißt sind.Der Support hat mich noch nie hängen lassen, eine Antwort vom Spliffsupport dauert zwischen 2-3 Stunden und man nimmt sich den Problemen der Kunden freundlich und lösungswillig an. Erst jetzt hat Spliff auf die Paketzusteller reagiert und einen neuen Paketzusteller genommen. Spliff bleibt die Nr. 1 für mich, Preis- Leistung ist auch super gut. Wer nicht bei Spliff bestellt ist selber schuld. Alle Pakete sind immer angekommen und so manches Paket hat mich echt vom Sockel gehauen, viele schöne Extras waren schon dabei. Man merkt das die Mitarbeiter es lieben was sie da tun und man wird als Kunde geschätzt. Immer wieder neue Produkte die einem die Entscheidung echt schwer macht. Ich bin zu 100% zufrieden mit Spliff, wenn der neue Paketzusteller hält was er verspricht gibt es nichts mehr zu motzen.\nDanke Spliff für eure tolle Arbeit und nein ich bekomme kein Schmiergeld von Spliff, das ist meine Erfahrung mit der besten Seite der Welt.  ","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2026-01-30T12:34:22.000Z","reviewSourceName":"BasicLink","verificationSource":"invitation","verificationLevel":"invited","hasDachExclusion":false}},"title":"SPLIFF?- Genau mein DIng","likes":0,"source":"BasicLink","dates":{"experiencedDate":"2026-01-30T00:00:00.000Z","publishedDate":"2026-01-30T12:34:22.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"686650212f24784db336b638","displayName":"Oliver Jünger","imageUrl":"https://user-images.trustpilot.com/686650212f24784db336b638/73x73.png","numberOfReviews":4,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":{"message":"Vielen, vielen Dank für dieses super ausführliche Feedback 🙏\nZu wissen, dass du seit Mai 2025 jeden Monat bestellst und dass dich Qualität, Packaging, unser Kundenservice und die kleinen Extras so überzeugen, bedeutet uns wirklich viel. ✨\n\nWir haben den Versanddienstleister tatsächlich gewechselt, um die Lieferprobleme zu lösen – und wir werden alles dafür tun, dass es jetzt endlich einwandfrei läuft.\nDanke für dein Vertrauen – es kommen noch einige richtig starke Neuheiten 😄\n\nDas Spliff-team","publishedDate":"2026-02-04T08:49:41.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":3,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"696f6613ba894733ddfa440b","filtered":false,"isPending":false,"text":"Super Support,  antworten sofort und auch Hilfreich. \n\nDie Produkte sind Erstklassig , werde hier öfter bestellen. ","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2026-01-20T13:25:07.000Z","reviewSourceName":"BasicLink","verificationSource":"invitation","verificationLevel":"invited","hasDachExclusion":false}},"title":"Super Support und Super Produkte","likes":0,"source":"BasicLink","dates":{"experiencedDate":"2026-01-19T00:00:00.000Z","publishedDate":"2026-01-20T13:25:07.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"696f660bc37c28a2b718283a","displayName":"Moris Mohs","imageUrl":"https://user-images.trustpilot.com/696f660bc37c28a2b718283a/73x73.png","numberOfReviews":1,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":{"message":"Vielen herzlichen Dank für Ihre positive Rückmeldung! Es freut uns sehr, dass Sie mit unserem Support und der Qualität unserer Produkte so zufrieden sind. Wir freuen uns darauf, Sie bald wieder bei uns begrüßen zu dürfen 😊\n\nDas Spliff-Team","publishedDate":"2026-01-22T16:04:24.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"696dda065fd8b422f79ff350","filtered":false,"isPending":false,"text":"Spliff ist genial. Ich bin sehr glücklich, dieses aus Zufall im Internet gefunden zu haben. Extrem zuverlässig :-) Clara kommuniziert immer sehr freundlich, kompetent und zeitnah. Gute Qualität, super Verpackung. Diskret. Gesund. Hilft bei körperlichen Schmerzen .Ein tolles Team - Danke :-)","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2026-01-19T09:15:18.000Z","reviewSourceName":"BasicLink","verificationSource":"invitation","verificationLevel":"invited","hasDachExclusion":false}},"title":"Spliff ist genial","likes":0,"source":"BasicLink","dates":{"experiencedDate":"2026-01-14T00:00:00.000Z","publishedDate":"2026-01-19T09:15:18.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"696dd9f84698843c3f69486a","displayName":"Colette Von Der Goltz-Koydl","imageUrl":"https://user-images.trustpilot.com/696dd9f84698843c3f69486a/73x73.png","numberOfReviews":1,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":{"message":"Vielen Dank für dieses großartige Feedback!\nWir freuen uns sehr, dass Sie Spliff entdeckt haben und dass unsere Produkte und unsere Betreuung Ihren Erwartungen entsprochen haben.\nDas gesamte Team, insbesondere Clara, bedankt sich für Ihre sehr ermutigenden Worte.\nWir freuen uns darauf, Sie wieder zu begleiten 🌿","publishedDate":"2026-01-22T16:02:02.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"69517d572b742c1f50b84dfc","filtered":false,"isPending":false,"text":"Ich habe viel erlebt mit „Clara“.  Ich habe immer Antwort bekommen, meistens nach einem Tag aber auch zwei und auch schon längere Zeit aber es hat sich immer jemand gemeldet, um mir und meiner Bestellung zu helfen. Manche schreiben hier, die Gummibärchen würden nicht knallen, finde ich auch leider, bei jeder meiner Bestellungen ist immer son Gummibärchen dabei, würde ich niemals bestellen, haben null Effekt.. Was ich immer bestelle ist dieser Sirum 300 in verschiedenen Geschmacksrichtungen, wobei der bittere Nachgang bei jedem Schluck schon echt bitter ist. Der Situp knallt gut, bin eigentlich leidenschaftliche kifferin, habe aber mit rauchen aufgehört. Ich bin im Training.wie man so schön sagt.. trotzdem knallt der Sirup sehr gut, ich finde nur irgendwie leider nicht so lange so 3 Stunden aber das mag an der EU und deren Bevormundung und der runter Regulierung liegen.","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-12-28T20:56:23.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Ich habe viel erlebt mit „Clara“","likes":0,"source":"Organic","dates":{"experiencedDate":"2025-12-28T00:00:00.000Z","publishedDate":"2025-12-28T20:56:23.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"61e82b58317986001258fdec","displayName":"Itz_akari-Chan UWU","imageUrl":"","numberOfReviews":5,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":{"message":"Guten Tag,\nvielen Dank für Ihr ausführliches Feedback und Ihre positiven Worte zu Ihrem Austausch mit unserem Service – die Qualität unseres Kundenservices ist für uns von zentraler Bedeutung.\nBezüglich der Gummies haben wir eine Charge identifiziert, die in Bezug auf die Wirkung nicht unseren Erwartungen entsprach. Dieses Problem wurde inzwischen behoben, und die aktuellen Chargen entsprechen wieder vollständig unseren Standards.\nEs freut uns sehr, dass Ihnen die Sirupe gefallen. Der leicht bittere Geschmack ist auf die hohe THC-Konzentration zurückzuführen. Die kürzere Wirkungsdauer erklärt sich durch die schnelle Aufnahme aufgrund der Verdauung und der flüssigen Produktform.\nWenn Sie eine länger anhaltende Wirkung suchen, empfehlen wir Ihnen, unsere Brownies zu probieren, deren langsamere Aufnahme in der Regel eine Wirkungsdauer von 4 bis 5 Stunden ermöglicht.\nVielen Dank nochmals für Ihr Vertrauen.\n\nIhr Spliff-Team","publishedDate":"2026-01-15T14:50:54.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"693feb8e25fa62e56647e73e","filtered":false,"isPending":false,"text":"Meine lezter Bestellung war nicht gut, habe keine Wirkung gemerkt, bin sehr enttäuscht.  Bestellung von 5 Dezember.  Habe aus Versehen noch 2 mal bestellt,  jetzt sitz ich da mit sch das nicht wirken, habe sogar als Tee getrunken,  auch keine Wirkung und schmecked eklig.  LG KATHLEEN ","rating":1,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-12-15T13:05:51.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Meine lezter Bestellung war nicht gut","likes":1,"source":"Organic","dates":{"experiencedDate":"2025-12-15T00:00:00.000Z","publishedDate":"2025-12-15T13:05:51.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"693feb853d98f013f1f98513","displayName":"Kathleen Kaeuffert","imageUrl":"https://user-images.trustpilot.com/693feb853d98f013f1f98513/73x73.png","numberOfReviews":1,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":{"message":"Hallo Kathleen,\nvielen Dank, dass Sie sich die Zeit genommen haben, Ihre Erfahrungen mit uns zu teilen. Es tut uns aufrichtig leid, dass Ihre Bestellung vom 5. Dezember nicht Ihren Erwartungen entsprochen hat und Sie nicht die gewünschten Ergebnisse erzielt haben.\n\nJeder Mensch kann unterschiedlich auf unsere Produkte reagieren, da mehrere Faktoren ihre Wirksamkeit beeinflussen können (Anwendungsweise, Dauer, Dosierung usw.). \nIch möchte Sie auch darauf hinweisen, dass es notwendig ist, Ihrer Zubereitung ein Fett (Milch, Öl...) hinzuzufügen, da Cannabinoide sich nicht in Wasser auflösen. Es ist daher normal, dass Sie durch den alleinigen Aufguss der Blüten keine Wirkung spüren.  \nAußerdem möchte ich daran erinnern, dass CBD in erster Linie eine entspannende und keine psychoaktive Wirkung hat. Wenn Sie eine stärkere Alternative bevorzugen, empfehlen wir Ihnen unsere THCX-Produktreihe.\nUnser Team steht unseren Kunden jederzeit zur Verfügung, um sie zu begleiten und bestmöglich zu beraten.\n\nWir haben auch festgestellt, dass Sie kürzlich eine weitere Bestellung aufgegeben haben, wofür wir uns herzlich bedanken. Wir hoffen, dass Sie mit dieser neuen Erfahrung voll und ganz zufrieden sein werden.\n\nZögern Sie nicht, unseren Kundenservice zu kontaktieren, um eine auf Ihr Profil zugeschnittene Beratung zu erhalten.\nWir stehen Ihnen jederzeit zur Verfügung und wünschen Ihnen einen schönen Tag.\n\nDas Spliff-Team","publishedDate":"2026-01-22T16:12:00.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"691f29b6b97d424267af52ad","filtered":false,"isPending":false,"text":"Erstens sind alle Produkte von Spliff wirklich gut. Zweitens hatte ich eine Reklamation zur einem der Vapes und Pods und habe sofort ganz unkompliziert Ersatz zugeschickt bekommen. Das freut mich sehr, weil die Dinger wirklich klasse sind! Aber vorsichtig anfangen, da steckt wirklich power hinter! Danke!","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-11-20T16:46:14.000Z","reviewSourceName":"BasicLink","verificationSource":"invitation","verificationLevel":"invited","hasDachExclusion":false}},"title":"Super Vapes, toller Service, gerne wieder!","likes":0,"source":"BasicLink","dates":{"experiencedDate":"2025-11-20T00:00:00.000Z","publishedDate":"2025-11-20T16:46:14.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"6345387007d7b20014c284f4","displayName":"Kunde HH Eidelstedt","imageUrl":"","numberOfReviews":9,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":{"message":"Hallo,\nvielen Dank für Ihr begeistertes Feedback! Wir freuen uns sehr, dass Ihnen unsere Vapes und unser Service gefallen haben. Sie haben Recht: Der Magic Vape mit der höchsten THCX-Konzentration in unserem Sortiment ist eine ausgezeichnete Wahl für erfahrene Konsumenten.\nGute Nachrichten: In den nächsten Wochen werden neue Geschmacksrichtungen erhältlich sein. Wir hoffen, dass sie Ihnen gefallen werden!\n\nDas Spliff-Team","publishedDate":"2026-01-22T15:42:15.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"68d6a82fd6f5a8d128c32aa1","filtered":false,"isPending":false,"text":"Diesmal ist Spliff durch die Schallmauer, das war in 3 Tagen da, ich war völlig überrascht. Das besonderst wichtige, es ist immer und immer wieder die exakt selbe Qualität. Ich hab jetzt schon so oft bestellt und kann das bestätigen. Die Auswahl wird immer größer und größer, ich bin Happy. Dann gibt es Cashback, du kriegst Geld von Spliff, wer da nicht zuschlägt ist wirklich selber Schuld. der Support ist immer noch voll auf Zack. Seit Mai bestelle ich regelmäßig, sogar in Vorkasse, alles Top.  ","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-09-26T16:50:23.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Zuverlääsig, schnell und gut","likes":0,"source":"Organic","dates":{"experiencedDate":"2025-09-02T00:00:00.000Z","publishedDate":"2025-09-26T16:50:23.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"686650212f24784db336b638","displayName":"Oliver Jünger","imageUrl":"https://user-images.trustpilot.com/686650212f24784db336b638/73x73.png","numberOfReviews":4,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":3,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"68b202675e8f48a1a945c12b","filtered":false,"isPending":false,"text":"Ich fande das high sehr gut und lange anhaltend. Leider ist der Geschmack des Sirups sehr bitter im Nachgeschmack, was allerdings auch nicht so schlimm ist da Mann sie ja kein Liter davon macht. ","rating":4,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-08-29T21:41:27.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Ich fande das high gut und langanhaltend ","likes":0,"source":"Organic","dates":{"experiencedDate":"2025-08-17T00:00:00.000Z","publishedDate":"2025-08-29T21:41:27.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"68b2021504313e5f636a2f8b","displayName":"Jerome","imageUrl":"","numberOfReviews":1,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"687b5fdfb06c5221012544aa","filtered":false,"isPending":false,"text":"Ich bin jetzt schon seit einem halben Jahr Kunde und kann das ganze daher recht gut einschätzen: Spliff ist für uns Europäer, solange man Cannabis nicht als normaler Bürger in öffentlichen Shops beziehen kann, wohl die beste Alternative.\n\nDie Edibles hauen dich kompletto weg, besonders der 300mg Sirup, danach kommst du gar nicht mehr klar, das hatte ich so auch noch nicht gesehen. Leute die schreiben, das wäre ohne Wirkung oder wäre Betrug, erzählen einfach Misst.\n\nDie THC Alternative \"THCX\" ist sehr angenehm zum Rauchen und man merkt einfach, das das kein Dreck von der Straße ist. Man kann nur nicht erwarten, dass es dich so wegghaut wie manch anderes was wir hier haben, aber dafür ist es gut gezüchtet und sehr angenehm.\n\nMein Lieferung kam bisher nie zu spät, auch wenn es immer circa 1 Woche dauert, weil es aus Süd Frankreich kommt.\n\nIch bin sehr zufrieden, auch wenn natürlich das THCX Gras gerne noch etwas mehr ballern kann.","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-07-19T11:05:35.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Stammkunde und kann es nur empfehlen ","likes":0,"source":"Organic","dates":{"experiencedDate":"2025-07-19T00:00:00.000Z","publishedDate":"2025-07-19T11:05:35.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"687b5fda192bd34730c89328","displayName":"Maximilian","imageUrl":"https://user-images.trustpilot.com/687b5fda192bd34730c89328/73x73.png","numberOfReviews":1,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"68285f1933dc54410b39c1cb","filtered":false,"isPending":false,"text":"Die Kommunikation mit spliff ist hervorragend. Und das gelieferte Material ist genau wie beschrieben. Die THCX-produkte sind der Knaller. Der rote Libanon, 2 Züge und ich war auf Wolke 7. Immer wieder gern","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-05-17T12:04:09.000Z","reviewSourceName":"BasicLink","verificationSource":"invitation","verificationLevel":"invited","hasDachExclusion":false}},"title":"Ultrageil","likes":0,"source":"BasicLink","dates":{"experiencedDate":"2025-05-15T00:00:00.000Z","publishedDate":"2025-05-17T12:04:09.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"6825f930bf768bd7fdfd2616","displayName":"Joachim Schaler","imageUrl":"https://user-images.trustpilot.com/6825f930bf768bd7fdfd2616/73x73.png","numberOfReviews":2,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":2,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"6825faed407f1555597d0e24","filtered":false,"isPending":false,"text":"Das hat ja reibungslos geklappt. Kommunikation super. Rezessionen anderer Kunden erfüllten mich mit Sorgen um mein Geld. Der rote Libanon so lecker und knallig. Gott muss ein libanese  sein 😂","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-05-15T16:32:13.000Z","reviewSourceName":"BasicLink","verificationSource":"invitation","verificationLevel":"invited","hasDachExclusion":false}},"title":"Alles prima schnelle lieferung immer wieder gern ","likes":0,"source":"BasicLink","dates":{"experiencedDate":"2025-05-15T00:00:00.000Z","publishedDate":"2025-05-15T16:32:13.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"6825f930bf768bd7fdfd2616","displayName":"Joachim Schaler","imageUrl":"https://user-images.trustpilot.com/6825f930bf768bd7fdfd2616/73x73.png","numberOfReviews":2,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":2,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"67f7b4b308c2244667ec1671","filtered":false,"isPending":false,"text":"Moin, ich habe Haschisch bestellt und bekam irgendwas was so aussehen sollte, aber selbst das \nhat nicht geklappt. Als Weltreisender habe ich gutes\nviel gutes Haschisch gesehen und konsumiert, das hier\nist lächerlich! Zum Glück ist bei uns legalisiert und ich auf so einen Müll nicht angewiesen. Hatte trotzdem neugierig bestellt und war extrem enttäuscht.","rating":1,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-04-10T14:08:19.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Moin, ","likes":1,"source":"Organic","dates":{"experiencedDate":"2025-04-10T00:00:00.000Z","publishedDate":"2025-04-10T14:08:19.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"657869e8daa9ba0012e8612b","displayName":"Niemann","imageUrl":"","numberOfReviews":6,"countryCode":"DE","hasImage":false,"isVerified":true},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"67f3e47fb057a865d91c0484","filtered":false,"isPending":false,"text":"Leckerlis sind von hervorragender Qualität und köstlich. \nDer Support ist eine 10/10.\nHerzlichen Dank \nPs: die Wirkung ist genau richtig. ","rating":5,"labels":{"merged":null,"verification":{"isVerified":true,"createdDateTime":"2025-04-07T16:43:11.000Z","reviewSourceName":"WooCommerce","verificationSource":"invitation","verificationLevel":"verified","hasDachExclusion":false}},"title":"Lecker 🥦🧸","likes":0,"source":"WooCommerce","dates":{"experiencedDate":"2025-03-21T00:00:00.000Z","publishedDate":"2025-04-07T16:43:11.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"67f3e47ed60ce20126f93774","displayName":"Boris","imageUrl":"","numberOfReviews":1,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"67f128e9029057785c1eff65","filtered":false,"isPending":false,"text":"Super Qualität, nicht nur bei den Produkten, sondern auch beim Support und Service!\nSchnelle zuverlässige Lieferung, faire Preise. ","rating":5,"labels":{"merged":null,"verification":{"isVerified":true,"createdDateTime":"2025-04-05T14:58:17.000Z","reviewSourceName":"WooCommerce","verificationSource":"invitation","verificationLevel":"verified","hasDachExclusion":false}},"title":"Super Qualität","likes":0,"source":"WooCommerce","dates":{"experiencedDate":"2025-03-19T00:00:00.000Z","publishedDate":"2025-04-05T14:58:17.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"67f128e8b0327a92b738801b","displayName":"Kai aus der Pfalz","imageUrl":"","numberOfReviews":1,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"67ee5267828a3b13657c3bf7","filtered":false,"isPending":false,"text":"Ware kommt flott ist toll verpackt und man kann sich wirklich drauf verlassen das alles klappt. Toll finde ich dass wenn etwas nicht lieferbar ist man es aber bestellt hat, angerufen wird und informiert wird. Zudem wird einem ein alternativ Artikel angeboten. Das find ich toll ","rating":5,"labels":{"merged":null,"verification":{"isVerified":true,"createdDateTime":"2025-04-03T11:18:31.000Z","reviewSourceName":"WooCommerce","verificationSource":"invitation","verificationLevel":"verified","hasDachExclusion":false}},"title":"Ware kommt flott ist toll verpackt und…","likes":0,"source":"WooCommerce","dates":{"experiencedDate":"2025-03-20T00:00:00.000Z","publishedDate":"2025-04-03T11:18:31.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"65eb629e44eae60012aba354","displayName":"Bianca Bajrami","imageUrl":"","numberOfReviews":2,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"67e5c75f22e38694c45c92e8","filtered":false,"isPending":false,"text":"Ich habe mich mal an den Sirup ran gemacht und probiert ,nach der Einnahme des Produktes kam nach 40 min. leicht die Wirkung ( angenehm und entspannt) ungefähr nach 70 min. wurde die Wirkung stärker und ich war in einer ganz anderen Galaxie, ich habe mir die Kopfhörer aufgesetzt und ska Musik angehört das war ein sehr schönes Gefühl (die Rakete ist absolut abgehoben) nach 5,5 Stunden ist die Wirkung abgeklungen (top und völlig ausreichend) der Geschmack war nicht so meins und vor allem nicht auf das Brötchen, das schmeckt nicht, ansonsten  war ich sehr zufrieden mit dem Produkt ","rating":5,"labels":{"merged":null,"verification":{"isVerified":true,"createdDateTime":"2025-03-27T23:47:11.000Z","reviewSourceName":"WooCommerce","verificationSource":"invitation","verificationLevel":"verified","hasDachExclusion":false}},"title":"Ich habe mich mal an den Sirup ran…","likes":0,"source":"WooCommerce","dates":{"experiencedDate":"2025-03-13T00:00:00.000Z","publishedDate":"2025-03-27T23:47:11.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"67e5c75e89ee14655d4b8896","displayName":"Maik Trumpf","imageUrl":"","numberOfReviews":1,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"67d7f080d32e7a0a94ff86cb","filtered":false,"isPending":false,"text":"Richtig gut. Je nach Dosis (1/4 - 1/2 - 3/4 oder ein ganzes Bärchen) alles dabei von einfach nur relaxed bis mehr als chillig zu klar und super angenehm breit. Klare Kaufempfehlung. Viel besser zu dosieren als rauchen und ein ganz anderes, viel bewussterer und klarer Zustand. Bestellen definitiv wieder. Ablauf war gut, Lieferung aus FR auch akzeptabel was die Zeit angeht.","rating":5,"labels":{"merged":null,"verification":{"isVerified":true,"createdDateTime":"2025-03-17T11:50:56.000Z","reviewSourceName":"WooCommerce","verificationSource":"invitation","verificationLevel":"verified","hasDachExclusion":false}},"title":"Klare Empfehlung","likes":0,"source":"WooCommerce","dates":{"experiencedDate":"2025-03-16T00:00:00.000Z","publishedDate":"2025-03-17T11:50:56.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"67d7f07f7062e8cc0ed5965b","displayName":"J. E.","imageUrl":"","numberOfReviews":1,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null}]],["65a8f486fe59a0421a2a19f2_de_delivery_service",[{"id":"698446f9ec4aefc02f477d6c","filtered":false,"isPending":false,"text":"Habe weitere Produckte getestet und kann nur Sagen Wow macht weiter so schnelle lieferung Top service und ein großer Dank geht an Clara die immer erreichbar ist bei allen fragen","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2026-02-05T09:30:01.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Habe weitere Produckte getestet und…","likes":0,"source":"Organic","dates":{"experiencedDate":"2026-02-05T00:00:00.000Z","publishedDate":"2026-02-05T09:30:01.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"6959697431cbb9360b883530","displayName":"Enrico Mirek Willing","imageUrl":"https://user-images.trustpilot.com/6959697431cbb9360b883530/73x73.png","numberOfReviews":5,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":{"message":"Vielen herzlichen Dank für Ihr großartiges Feedback! ✨\n\nWir freuen uns sehr, dass Ihre Erfahrung Ihren Erwartungen entsprochen hat.\n\nEin großes Dankeschön auch für Ihre besondere Erwähnung von Clara: Wir werden ihr Ihre Nachricht selbstverständlich weiterleiten – sie wird sich sehr über Ihre Worte freuen.\n\nWir freuen uns darauf, Sie bald wieder bedienen zu dürfen! 💚\n\nDas Spliff-Team","publishedDate":"2026-02-18T09:01:19.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":2,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"697c892e1c2d2768305dac3d","filtered":false,"isPending":false,"text":"Seit Mai 2025 bestelle ich jeden Monat bei Spliff. Die Qualität ist der Hammer und immer exakt gleich gut. Das Produkt kommt in edlen schwarzen Tüten die luftdicht verschweißt sind.Der Support hat mich noch nie hängen lassen, eine Antwort vom Spliffsupport dauert zwischen 2-3 Stunden und man nimmt sich den Problemen der Kunden freundlich und lösungswillig an. Erst jetzt hat Spliff auf die Paketzusteller reagiert und einen neuen Paketzusteller genommen. Spliff bleibt die Nr. 1 für mich, Preis- Leistung ist auch super gut. Wer nicht bei Spliff bestellt ist selber schuld. Alle Pakete sind immer angekommen und so manches Paket hat mich echt vom Sockel gehauen, viele schöne Extras waren schon dabei. Man merkt das die Mitarbeiter es lieben was sie da tun und man wird als Kunde geschätzt. Immer wieder neue Produkte die einem die Entscheidung echt schwer macht. Ich bin zu 100% zufrieden mit Spliff, wenn der neue Paketzusteller hält was er verspricht gibt es nichts mehr zu motzen.\nDanke Spliff für eure tolle Arbeit und nein ich bekomme kein Schmiergeld von Spliff, das ist meine Erfahrung mit der besten Seite der Welt.  ","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2026-01-30T12:34:22.000Z","reviewSourceName":"BasicLink","verificationSource":"invitation","verificationLevel":"invited","hasDachExclusion":false}},"title":"SPLIFF?- Genau mein DIng","likes":0,"source":"BasicLink","dates":{"experiencedDate":"2026-01-30T00:00:00.000Z","publishedDate":"2026-01-30T12:34:22.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"686650212f24784db336b638","displayName":"Oliver Jünger","imageUrl":"https://user-images.trustpilot.com/686650212f24784db336b638/73x73.png","numberOfReviews":4,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":{"message":"Vielen, vielen Dank für dieses super ausführliche Feedback 🙏\nZu wissen, dass du seit Mai 2025 jeden Monat bestellst und dass dich Qualität, Packaging, unser Kundenservice und die kleinen Extras so überzeugen, bedeutet uns wirklich viel. ✨\n\nWir haben den Versanddienstleister tatsächlich gewechselt, um die Lieferprobleme zu lösen – und wir werden alles dafür tun, dass es jetzt endlich einwandfrei läuft.\nDanke für dein Vertrauen – es kommen noch einige richtig starke Neuheiten 😄\n\nDas Spliff-team","publishedDate":"2026-02-04T08:49:41.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":3,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"69714c603d8c4ccd488ebd39","filtered":false,"isPending":false,"text":"Der Shop ist sehr übersichtlich gestaltet, was den Einkauf gemütlich gestaltet.\n\nBei Problemen wird umgehend zur Seite gestanden und geholfen. \n\nLieferung geht zackig von dannen... Ich bin sehr zufrieden mit allem und kann eine klare Empfehlung aussprechen ","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2026-01-22T00:00:00.000Z","reviewSourceName":"BasicLink","verificationSource":"invitation","verificationLevel":"invited","hasDachExclusion":false}},"title":"Der Shop ist sehr übersichtlich…","likes":0,"source":"BasicLink","dates":{"experiencedDate":"2026-01-15T00:00:00.000Z","publishedDate":"2026-01-22T00:00:00.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"69714c25c37c2800c81ae62e","displayName":"Keule","imageUrl":"","numberOfReviews":1,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":{"message":"Vielen herzlichen Dank für Ihre Nachricht und Ihre klare Empfehlung! \nEs freut uns sehr, dass die Übersichtlichkeit unseres Shops, die Reaktionsschnelligkeit unseres Supports und die schnelle Lieferung zu Ihrer Zufriedenheit beigetragen haben. \nDas gesamte Team bedankt sich herzlich für Ihr Vertrauen 😊\n\nDas Spliff-Team","publishedDate":"2026-01-22T16:09:41.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"695fc5cc1f25bd7787e15f5a","filtered":false,"isPending":false,"text":"Habe schon öfter dort den Sirup bestellt, der mir bei meinen Depressionen abends zum Abspannen hilft. Da ich kein Weed mehr rauche bzw. generell nicht mehr rauche, kommt der Sirup als Alternative gut daher. Bei meiner letzten Bestellung kam es dank DHL zu Lieferproblemen, der Support von Spliff war in dem Fall sehr schnell und Kundenorientiert und hilfsbereit.Gibt eigentlich nichts zu bemängeln, Ware sowie Service Top ;-)","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2026-01-08T16:57:16.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Habe schon öfter dort den Sirup…","likes":0,"source":"Organic","dates":{"experiencedDate":"2026-01-08T00:00:00.000Z","publishedDate":"2026-01-08T16:57:16.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"6608108717cfe20012d1b2b3","displayName":"C.Husemann","imageUrl":"","numberOfReviews":6,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":{"message":"Vielen Dank für Ihr positives Feedback und Ihre Treue 😊\nWir freuen uns, dass Sie mit dem Magic Potion zufrieden sind und dass er für Sie eine gute Alternative darstellt.\nTrotz der Lieferprobleme, die außerhalb unserer Kontrolle lagen, sind wir froh, Ihnen schnell helfen zu können.\nBis bald und vielen Dank für Ihr Vertrauen!\n\nDas Spliff-Team","publishedDate":"2026-01-22T15:41:12.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"6911142b30a74a92f15cda04","filtered":false,"isPending":false,"text":"Die Lieferungen sind fehlerhaft, auf Nachfragen wird nicht reagiert,  geld wird einfach einbehalten obwohl die qaren zurück ging laut DHL ","rating":1,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-11-10T00:22:35.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Die Lieferungen sind fehlerhaft","likes":1,"source":"Organic","dates":{"experiencedDate":"2025-11-01T00:00:00.000Z","publishedDate":"2025-11-10T00:22:35.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"6911142451678e8bfa8c03fa","displayName":"Oliver Rudolf","imageUrl":"https://user-images.trustpilot.com/6911142451678e8bfa8c03fa/73x73.png","numberOfReviews":1,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":{"message":"Hallo Oliver,\n\nvielen Dank für Ihre Nachricht. Nach Ihrem Gespräch mit unserem Kundenservice wurde Ihre Bestellung erneut versandt. Wir entschuldigen uns nochmals für die Unannehmlichkeiten, die Ihnen durch den Spediteur entstanden sind.\nWir haben festgestellt, dass Sie anschließend mehrere Bestellungen aufgegeben haben, die ohne Zwischenfälle geliefert wurden, was uns sehr freut. \nUnser gesamtes Team ist täglich bemüht, die Qualität unserer Produkte und Dienstleistungen zu verbessern. Aus diesem Grund haben wir eine Partnerschaft mit einem neuen Transportunternehmen geschlossen, von dem wir hoffen, dass es Sie zufriedenstellen wird.\nSelbstverständlich stehen wir Ihnen bei Bedarf jederzeit zur Verfügung.\n\nDas Spliff-Team","publishedDate":"2026-01-22T16:13:44.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"69087dd695eadb340ac3062a","filtered":false,"isPending":false,"text":"Hallo. \n\nIch habe etwas auf der Website bestellt (Sirup) und darauf mehrere Tage gewartet, als es laut DPD endlich abgeholt wurde, stand dort plötzlich, dass das Paket nicht zugestellt werden konnte und dass das Paket zurück an den Absender geschickt wird. \nWeder war DPD bei mir, noch krieg man irgendeine Info vom Spliffstore. Ich habe im vorausbezahlt und kriege weder online, noch anderswo Informationen.\nPaket kommt nicht und Geld ist weg. \nFür mich sind die Bewertung hier alle Fake und der Shop Scam. \nNie wieder werd ich bei den bestellen, da kann ich das Geld auch anzünden. ","rating":1,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-11-03T12:03:02.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Lieferung kommt nicht an","likes":1,"source":"Organic","dates":{"experiencedDate":"2025-11-01T00:00:00.000Z","publishedDate":"2025-11-03T12:03:02.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"5fd220f033b62e0019430cae","displayName":"Rapfanatik Ultra","imageUrl":"","numberOfReviews":6,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":{"message":"Guten Tag,\n\nwir bedauern diese schlechte Erfahrung sehr und verstehen Ihre Unzufriedenheit.\n\nEs kam insbesondere bei unseren Sendungen mit dem Postdienst DPD zu Lieferproblemen. Aus diesem Grund haben wir unseren Logistikpartner gewechselt, um die Zuverlässigkeit und Qualität unseres Services zu verbessern. Unsere ersten Eindrücke von den jüngsten Sendungen sind ausgezeichnet. \n\nSeien Sie versichert, dass unser Kundenservice Ihnen gerne zur Verfügung steht, um die Situation zu klären. Zögern Sie nicht, uns unter Angabe Ihrer Bestellnummer zu kontaktieren.\n\nDas Team von Spliffstore","publishedDate":"2026-01-29T13:02:13.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"68d6a82fd6f5a8d128c32aa1","filtered":false,"isPending":false,"text":"Diesmal ist Spliff durch die Schallmauer, das war in 3 Tagen da, ich war völlig überrascht. Das besonderst wichtige, es ist immer und immer wieder die exakt selbe Qualität. Ich hab jetzt schon so oft bestellt und kann das bestätigen. Die Auswahl wird immer größer und größer, ich bin Happy. Dann gibt es Cashback, du kriegst Geld von Spliff, wer da nicht zuschlägt ist wirklich selber Schuld. der Support ist immer noch voll auf Zack. Seit Mai bestelle ich regelmäßig, sogar in Vorkasse, alles Top.  ","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-09-26T16:50:23.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Zuverlääsig, schnell und gut","likes":0,"source":"Organic","dates":{"experiencedDate":"2025-09-02T00:00:00.000Z","publishedDate":"2025-09-26T16:50:23.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"686650212f24784db336b638","displayName":"Oliver Jünger","imageUrl":"https://user-images.trustpilot.com/686650212f24784db336b638/73x73.png","numberOfReviews":4,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":3,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"687b5fdfb06c5221012544aa","filtered":false,"isPending":false,"text":"Ich bin jetzt schon seit einem halben Jahr Kunde und kann das ganze daher recht gut einschätzen: Spliff ist für uns Europäer, solange man Cannabis nicht als normaler Bürger in öffentlichen Shops beziehen kann, wohl die beste Alternative.\n\nDie Edibles hauen dich kompletto weg, besonders der 300mg Sirup, danach kommst du gar nicht mehr klar, das hatte ich so auch noch nicht gesehen. Leute die schreiben, das wäre ohne Wirkung oder wäre Betrug, erzählen einfach Misst.\n\nDie THC Alternative \"THCX\" ist sehr angenehm zum Rauchen und man merkt einfach, das das kein Dreck von der Straße ist. Man kann nur nicht erwarten, dass es dich so wegghaut wie manch anderes was wir hier haben, aber dafür ist es gut gezüchtet und sehr angenehm.\n\nMein Lieferung kam bisher nie zu spät, auch wenn es immer circa 1 Woche dauert, weil es aus Süd Frankreich kommt.\n\nIch bin sehr zufrieden, auch wenn natürlich das THCX Gras gerne noch etwas mehr ballern kann.","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-07-19T11:05:35.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Stammkunde und kann es nur empfehlen ","likes":0,"source":"Organic","dates":{"experiencedDate":"2025-07-19T00:00:00.000Z","publishedDate":"2025-07-19T11:05:35.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"687b5fda192bd34730c89328","displayName":"Maximilian","imageUrl":"https://user-images.trustpilot.com/687b5fda192bd34730c89328/73x73.png","numberOfReviews":1,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"687787ee0ceaf86e9cb6b55f","filtered":false,"isPending":false,"text":"Schnelle Lieferung! \nIch hatte erst kürzlich Liederprobleme, aber das LAG NICHT an dem tollen Spliff-Team!\nEs lag an meinem deutschen Logistiker DHL!\nOhne Rückmeldung weshalb der lieferstatus seit 5 Tagen nicht aktualisiert wurde, habe ich an Tag 6 meine Ware endlich abholen dürfen!\nDas Spliff-Team hat derweil zügig Hilfe angeboten aber auch zum Zeitpunkt der Rückmeldung es fragwürdig gefunden, dass die Lieferung pünktlich versendet und doch so lange brauchte, um in einer Packstation zu landen.\n\nDanke Spliff-Team!\nSuper Marke übrigens Magic Candy Sirup 🥳","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-07-16T13:07:26.000Z","reviewSourceName":"BasicLink","verificationSource":"invitation","verificationLevel":"invited","hasDachExclusion":false}},"title":"Schnelle Lieferung","likes":0,"source":"BasicLink","dates":{"experiencedDate":"2025-07-15T00:00:00.000Z","publishedDate":"2025-07-16T13:07:26.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"687787e520554d35213db51e","displayName":"bella n","imageUrl":"https://user-images.trustpilot.com/687787e520554d35213db51e/73x73.png","numberOfReviews":1,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"686655e085810f38251ea231","filtered":false,"isPending":false,"text":"Ich hab mich an den Support gewendet, per E-Mail, keine 1,5 Stunden später hatte ich eine Antwort, das Spliff nicht antwortet ist ein übles \"Schreckgespenst\". Auf erneute Frage, hatte ich noch schneller eine Antwort, ca. 1 Stunde. Ich war freundlich, das Spliff Team war auch sehr freundlich, erklärte mir wo es hängen könnte, denn ab der Post, selbst auf dem Jupiter, muss Spliff bei der \"Post\" nachfragen und kann dann wieder informieren. Müsste man verstehen können.\nGrüße an das Spliff- Team, ich bin begeistert. \nZur Sendung, da gehören dafür 5 Sterne hintendran, kauf ich auf jeden Fall wieder ein, wenn es kurz hakt, cool bleiben ;) \nTHX SPLIFF  ","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-07-03T12:05:20.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Schnellster Support ever","likes":0,"source":"Organic","dates":{"experiencedDate":"2025-07-03T00:00:00.000Z","publishedDate":"2025-07-03T12:05:20.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"686650212f24784db336b638","displayName":"Oliver Jünger","imageUrl":"https://user-images.trustpilot.com/686650212f24784db336b638/73x73.png","numberOfReviews":4,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":3,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"6821e8c0ac95db9faf211cdc","filtered":false,"isPending":false,"text":"Bis heute keine Lieferung erhalten. Fühle mich von Spliff betrogen!\n14.05.25-Ware ist immer noch nicht angekommen.\nSendung hängt bei DHL wohl fest.\nIst möglicherweise eine LOGISTIK-Sache ???\nVielleicht anderer Spediteur ?\n","rating":2,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-05-12T14:25:36.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Bis heute keine Lieferung erhalten","likes":0,"source":"Organic","dates":{"experiencedDate":"2025-05-12T00:00:00.000Z","publishedDate":"2025-05-12T14:25:36.000Z","updatedDate":"2025-05-14T15:40:10.000Z","submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"654f68881b8887001134d9c0","displayName":"Det","imageUrl":"","numberOfReviews":4,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"681315d0a4a75bced57191b7","filtered":false,"isPending":false,"text":"Ergänzung des ursprünglichen Textes: Nachdem Spliff zunächst nicht reagieert hatte, wurde in der Zwischenzeit eine umfangreiche Suche gestartet. Leider lässt sich der Standort der Sendung nicht mehr bestimmen, auch, weil zwei Transportdienstleister involviert sind. Heute hat mir Spliff die erneute Sendung oder vollständige Rückerstattung meiner Auslagen angeboten. Das nenne ich praktizierte Kundenorientierung. Deswegen Heraufstufung auf vier Sterne. Ursprünglicher Text v. 30.04.25: \"Eigentlich null Sterne. Ich habe Anfang April was bestellt. Als die Zahlung anfangs nicht korrekt war (zu wenig, weil ich ein Bonusangebot genutzt habe) wurde ich sofort von einer deutsch sprechenden Mitarbeiterin angerufen.\nSeitdem warte ich auf die Postsendung. Habe die Firma Spliff mehrfach angemailt, habe auch zweimal auf den AB dort gesprochen. Reaktion bisher: keine. Wenn die Kohle dort ist, scheint die Sache für die Firma erledigt zu sein, dann sind Kontaktversuche offenbar lästig und es wird nicht reagiert. Unterirdischer \"Service\", JAMAIS PLUS\"  ","rating":4,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-05-01T08:33:52.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Eigentlich null Sterne - korrigiert auf vier Sterne","likes":0,"source":"Organic","dates":{"experiencedDate":"2025-04-30T00:00:00.000Z","publishedDate":"2025-05-01T08:33:52.000Z","updatedDate":"2025-06-12T09:12:24.000Z","submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"52510d2000006400014f3916","displayName":"Rainer Gottlieb","imageUrl":"","numberOfReviews":1,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"67f6b74ffb21415af6004a28","filtered":false,"isPending":false,"text":"Alles bestens gelaufen. Von der Bestellung bis zur Auslieferung, inklusive Infos per Mail.","rating":5,"labels":{"merged":null,"verification":{"isVerified":true,"createdDateTime":"2025-04-09T20:07:11.000Z","reviewSourceName":"WooCommerce","verificationSource":"invitation","verificationLevel":"verified","hasDachExclusion":false}},"title":"Alles bestens gelaufen","likes":0,"source":"WooCommerce","dates":{"experiencedDate":"2025-03-20T00:00:00.000Z","publishedDate":"2025-04-09T20:07:11.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"5f284d86b93ad268c2986b1b","displayName":"wiesaer","imageUrl":"","numberOfReviews":2,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"67f128e9029057785c1eff65","filtered":false,"isPending":false,"text":"Super Qualität, nicht nur bei den Produkten, sondern auch beim Support und Service!\nSchnelle zuverlässige Lieferung, faire Preise. ","rating":5,"labels":{"merged":null,"verification":{"isVerified":true,"createdDateTime":"2025-04-05T14:58:17.000Z","reviewSourceName":"WooCommerce","verificationSource":"invitation","verificationLevel":"verified","hasDachExclusion":false}},"title":"Super Qualität","likes":0,"source":"WooCommerce","dates":{"experiencedDate":"2025-03-19T00:00:00.000Z","publishedDate":"2025-04-05T14:58:17.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"67f128e8b0327a92b738801b","displayName":"Kai aus der Pfalz","imageUrl":"","numberOfReviews":1,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"67ebdf19a3d8f6cda60f9e94","filtered":false,"isPending":false,"text":"Trotz ein paar Kiefer Problemen durch den deutschen lieferdienst was nichts mit dem Shop zu tun hat ist alles super und reibungslos gelaufen der Service war super und meine Bestellung unschlagbar ","rating":5,"labels":{"merged":null,"verification":{"isVerified":true,"createdDateTime":"2025-04-01T14:42:01.000Z","reviewSourceName":"WooCommerce","verificationSource":"invitation","verificationLevel":"verified","hasDachExclusion":false}},"title":"Service ","likes":0,"source":"WooCommerce","dates":{"experiencedDate":"2025-03-18T00:00:00.000Z","publishedDate":"2025-04-01T14:42:01.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"67ebdf1774626a557153473c","displayName":"Nick","imageUrl":"","numberOfReviews":1,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"67ea4a2c7e55827507f7e7d3","filtered":false,"isPending":false,"text":"Eine tolle Erfahrung! Der etwas andere Genuss.\n\nDie gesamte Lieferung war einwandfrei\n\nSehr gerne wieder","rating":5,"labels":{"merged":null,"verification":{"isVerified":true,"createdDateTime":"2025-03-31T09:54:20.000Z","reviewSourceName":"WooCommerce","verificationSource":"invitation","verificationLevel":"verified","hasDachExclusion":false}},"title":"Eine tolle Erfahrung","likes":0,"source":"WooCommerce","dates":{"experiencedDate":"2025-03-17T00:00:00.000Z","publishedDate":"2025-03-31T09:54:20.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"678dd8d3a82c15dce7a32d94","displayName":"RALF KAEHLER","imageUrl":"","numberOfReviews":2,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"67dc9313ed6139eed8668d60","filtered":false,"isPending":false,"text":"Erste Sendung ging verloren , Spliff hat zeitnah reagieren und eine neue Sendung geschickt.\nAlles prima.","rating":5,"labels":{"merged":null,"verification":{"isVerified":true,"createdDateTime":"2025-03-21T00:13:39.000Z","reviewSourceName":"WooCommerce","verificationSource":"invitation","verificationLevel":"verified","hasDachExclusion":false}},"title":"Ersatz ","likes":0,"source":"WooCommerce","dates":{"experiencedDate":"2025-03-11T00:00:00.000Z","publishedDate":"2025-03-21T00:13:39.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"67dc93119d161f47d4427d0a","displayName":"MaSchu","imageUrl":"","numberOfReviews":1,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"67d7f080d32e7a0a94ff86cb","filtered":false,"isPending":false,"text":"Richtig gut. Je nach Dosis (1/4 - 1/2 - 3/4 oder ein ganzes Bärchen) alles dabei von einfach nur relaxed bis mehr als chillig zu klar und super angenehm breit. Klare Kaufempfehlung. Viel besser zu dosieren als rauchen und ein ganz anderes, viel bewussterer und klarer Zustand. Bestellen definitiv wieder. Ablauf war gut, Lieferung aus FR auch akzeptabel was die Zeit angeht.","rating":5,"labels":{"merged":null,"verification":{"isVerified":true,"createdDateTime":"2025-03-17T11:50:56.000Z","reviewSourceName":"WooCommerce","verificationSource":"invitation","verificationLevel":"verified","hasDachExclusion":false}},"title":"Klare Empfehlung","likes":0,"source":"WooCommerce","dates":{"experiencedDate":"2025-03-16T00:00:00.000Z","publishedDate":"2025-03-17T11:50:56.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"67d7f07f7062e8cc0ed5965b","displayName":"J. E.","imageUrl":"","numberOfReviews":1,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null}]],["65a8f486fe59a0421a2a19f2_de_order",[{"id":"697c892e1c2d2768305dac3d","filtered":false,"isPending":false,"text":"Seit Mai 2025 bestelle ich jeden Monat bei Spliff. Die Qualität ist der Hammer und immer exakt gleich gut. Das Produkt kommt in edlen schwarzen Tüten die luftdicht verschweißt sind.Der Support hat mich noch nie hängen lassen, eine Antwort vom Spliffsupport dauert zwischen 2-3 Stunden und man nimmt sich den Problemen der Kunden freundlich und lösungswillig an. Erst jetzt hat Spliff auf die Paketzusteller reagiert und einen neuen Paketzusteller genommen. Spliff bleibt die Nr. 1 für mich, Preis- Leistung ist auch super gut. Wer nicht bei Spliff bestellt ist selber schuld. Alle Pakete sind immer angekommen und so manches Paket hat mich echt vom Sockel gehauen, viele schöne Extras waren schon dabei. Man merkt das die Mitarbeiter es lieben was sie da tun und man wird als Kunde geschätzt. Immer wieder neue Produkte die einem die Entscheidung echt schwer macht. Ich bin zu 100% zufrieden mit Spliff, wenn der neue Paketzusteller hält was er verspricht gibt es nichts mehr zu motzen.\nDanke Spliff für eure tolle Arbeit und nein ich bekomme kein Schmiergeld von Spliff, das ist meine Erfahrung mit der besten Seite der Welt.  ","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2026-01-30T12:34:22.000Z","reviewSourceName":"BasicLink","verificationSource":"invitation","verificationLevel":"invited","hasDachExclusion":false}},"title":"SPLIFF?- Genau mein DIng","likes":0,"source":"BasicLink","dates":{"experiencedDate":"2026-01-30T00:00:00.000Z","publishedDate":"2026-01-30T12:34:22.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"686650212f24784db336b638","displayName":"Oliver Jünger","imageUrl":"https://user-images.trustpilot.com/686650212f24784db336b638/73x73.png","numberOfReviews":4,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":{"message":"Vielen, vielen Dank für dieses super ausführliche Feedback 🙏\nZu wissen, dass du seit Mai 2025 jeden Monat bestellst und dass dich Qualität, Packaging, unser Kundenservice und die kleinen Extras so überzeugen, bedeutet uns wirklich viel. ✨\n\nWir haben den Versanddienstleister tatsächlich gewechselt, um die Lieferprobleme zu lösen – und wir werden alles dafür tun, dass es jetzt endlich einwandfrei läuft.\nDanke für dein Vertrauen – es kommen noch einige richtig starke Neuheiten 😄\n\nDas Spliff-team","publishedDate":"2026-02-04T08:49:41.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":3,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"695fc5cc1f25bd7787e15f5a","filtered":false,"isPending":false,"text":"Habe schon öfter dort den Sirup bestellt, der mir bei meinen Depressionen abends zum Abspannen hilft. Da ich kein Weed mehr rauche bzw. generell nicht mehr rauche, kommt der Sirup als Alternative gut daher. Bei meiner letzten Bestellung kam es dank DHL zu Lieferproblemen, der Support von Spliff war in dem Fall sehr schnell und Kundenorientiert und hilfsbereit.Gibt eigentlich nichts zu bemängeln, Ware sowie Service Top ;-)","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2026-01-08T16:57:16.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Habe schon öfter dort den Sirup…","likes":0,"source":"Organic","dates":{"experiencedDate":"2026-01-08T00:00:00.000Z","publishedDate":"2026-01-08T16:57:16.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"6608108717cfe20012d1b2b3","displayName":"C.Husemann","imageUrl":"","numberOfReviews":6,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":{"message":"Vielen Dank für Ihr positives Feedback und Ihre Treue 😊\nWir freuen uns, dass Sie mit dem Magic Potion zufrieden sind und dass er für Sie eine gute Alternative darstellt.\nTrotz der Lieferprobleme, die außerhalb unserer Kontrolle lagen, sind wir froh, Ihnen schnell helfen zu können.\nBis bald und vielen Dank für Ihr Vertrauen!\n\nDas Spliff-Team","publishedDate":"2026-01-22T15:41:12.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"69517d572b742c1f50b84dfc","filtered":false,"isPending":false,"text":"Ich habe viel erlebt mit „Clara“.  Ich habe immer Antwort bekommen, meistens nach einem Tag aber auch zwei und auch schon längere Zeit aber es hat sich immer jemand gemeldet, um mir und meiner Bestellung zu helfen. Manche schreiben hier, die Gummibärchen würden nicht knallen, finde ich auch leider, bei jeder meiner Bestellungen ist immer son Gummibärchen dabei, würde ich niemals bestellen, haben null Effekt.. Was ich immer bestelle ist dieser Sirum 300 in verschiedenen Geschmacksrichtungen, wobei der bittere Nachgang bei jedem Schluck schon echt bitter ist. Der Situp knallt gut, bin eigentlich leidenschaftliche kifferin, habe aber mit rauchen aufgehört. Ich bin im Training.wie man so schön sagt.. trotzdem knallt der Sirup sehr gut, ich finde nur irgendwie leider nicht so lange so 3 Stunden aber das mag an der EU und deren Bevormundung und der runter Regulierung liegen.","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-12-28T20:56:23.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Ich habe viel erlebt mit „Clara“","likes":0,"source":"Organic","dates":{"experiencedDate":"2025-12-28T00:00:00.000Z","publishedDate":"2025-12-28T20:56:23.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"61e82b58317986001258fdec","displayName":"Itz_akari-Chan UWU","imageUrl":"","numberOfReviews":5,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":{"message":"Guten Tag,\nvielen Dank für Ihr ausführliches Feedback und Ihre positiven Worte zu Ihrem Austausch mit unserem Service – die Qualität unseres Kundenservices ist für uns von zentraler Bedeutung.\nBezüglich der Gummies haben wir eine Charge identifiziert, die in Bezug auf die Wirkung nicht unseren Erwartungen entsprach. Dieses Problem wurde inzwischen behoben, und die aktuellen Chargen entsprechen wieder vollständig unseren Standards.\nEs freut uns sehr, dass Ihnen die Sirupe gefallen. Der leicht bittere Geschmack ist auf die hohe THC-Konzentration zurückzuführen. Die kürzere Wirkungsdauer erklärt sich durch die schnelle Aufnahme aufgrund der Verdauung und der flüssigen Produktform.\nWenn Sie eine länger anhaltende Wirkung suchen, empfehlen wir Ihnen, unsere Brownies zu probieren, deren langsamere Aufnahme in der Regel eine Wirkungsdauer von 4 bis 5 Stunden ermöglicht.\nVielen Dank nochmals für Ihr Vertrauen.\n\nIhr Spliff-Team","publishedDate":"2026-01-15T14:50:54.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"693feb8e25fa62e56647e73e","filtered":false,"isPending":false,"text":"Meine lezter Bestellung war nicht gut, habe keine Wirkung gemerkt, bin sehr enttäuscht.  Bestellung von 5 Dezember.  Habe aus Versehen noch 2 mal bestellt,  jetzt sitz ich da mit sch das nicht wirken, habe sogar als Tee getrunken,  auch keine Wirkung und schmecked eklig.  LG KATHLEEN ","rating":1,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-12-15T13:05:51.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Meine lezter Bestellung war nicht gut","likes":1,"source":"Organic","dates":{"experiencedDate":"2025-12-15T00:00:00.000Z","publishedDate":"2025-12-15T13:05:51.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"693feb853d98f013f1f98513","displayName":"Kathleen Kaeuffert","imageUrl":"https://user-images.trustpilot.com/693feb853d98f013f1f98513/73x73.png","numberOfReviews":1,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":{"message":"Hallo Kathleen,\nvielen Dank, dass Sie sich die Zeit genommen haben, Ihre Erfahrungen mit uns zu teilen. Es tut uns aufrichtig leid, dass Ihre Bestellung vom 5. Dezember nicht Ihren Erwartungen entsprochen hat und Sie nicht die gewünschten Ergebnisse erzielt haben.\n\nJeder Mensch kann unterschiedlich auf unsere Produkte reagieren, da mehrere Faktoren ihre Wirksamkeit beeinflussen können (Anwendungsweise, Dauer, Dosierung usw.). \nIch möchte Sie auch darauf hinweisen, dass es notwendig ist, Ihrer Zubereitung ein Fett (Milch, Öl...) hinzuzufügen, da Cannabinoide sich nicht in Wasser auflösen. Es ist daher normal, dass Sie durch den alleinigen Aufguss der Blüten keine Wirkung spüren.  \nAußerdem möchte ich daran erinnern, dass CBD in erster Linie eine entspannende und keine psychoaktive Wirkung hat. Wenn Sie eine stärkere Alternative bevorzugen, empfehlen wir Ihnen unsere THCX-Produktreihe.\nUnser Team steht unseren Kunden jederzeit zur Verfügung, um sie zu begleiten und bestmöglich zu beraten.\n\nWir haben auch festgestellt, dass Sie kürzlich eine weitere Bestellung aufgegeben haben, wofür wir uns herzlich bedanken. Wir hoffen, dass Sie mit dieser neuen Erfahrung voll und ganz zufrieden sein werden.\n\nZögern Sie nicht, unseren Kundenservice zu kontaktieren, um eine auf Ihr Profil zugeschnittene Beratung zu erhalten.\nWir stehen Ihnen jederzeit zur Verfügung und wünschen Ihnen einen schönen Tag.\n\nDas Spliff-Team","publishedDate":"2026-01-22T16:12:00.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"69087dd695eadb340ac3062a","filtered":false,"isPending":false,"text":"Hallo. \n\nIch habe etwas auf der Website bestellt (Sirup) und darauf mehrere Tage gewartet, als es laut DPD endlich abgeholt wurde, stand dort plötzlich, dass das Paket nicht zugestellt werden konnte und dass das Paket zurück an den Absender geschickt wird. \nWeder war DPD bei mir, noch krieg man irgendeine Info vom Spliffstore. Ich habe im vorausbezahlt und kriege weder online, noch anderswo Informationen.\nPaket kommt nicht und Geld ist weg. \nFür mich sind die Bewertung hier alle Fake und der Shop Scam. \nNie wieder werd ich bei den bestellen, da kann ich das Geld auch anzünden. ","rating":1,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-11-03T12:03:02.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Lieferung kommt nicht an","likes":1,"source":"Organic","dates":{"experiencedDate":"2025-11-01T00:00:00.000Z","publishedDate":"2025-11-03T12:03:02.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"5fd220f033b62e0019430cae","displayName":"Rapfanatik Ultra","imageUrl":"","numberOfReviews":6,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":{"message":"Guten Tag,\n\nwir bedauern diese schlechte Erfahrung sehr und verstehen Ihre Unzufriedenheit.\n\nEs kam insbesondere bei unseren Sendungen mit dem Postdienst DPD zu Lieferproblemen. Aus diesem Grund haben wir unseren Logistikpartner gewechselt, um die Zuverlässigkeit und Qualität unseres Services zu verbessern. Unsere ersten Eindrücke von den jüngsten Sendungen sind ausgezeichnet. \n\nSeien Sie versichert, dass unser Kundenservice Ihnen gerne zur Verfügung steht, um die Situation zu klären. Zögern Sie nicht, uns unter Angabe Ihrer Bestellnummer zu kontaktieren.\n\nDas Team von Spliffstore","publishedDate":"2026-01-29T13:02:13.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"68d6a82fd6f5a8d128c32aa1","filtered":false,"isPending":false,"text":"Diesmal ist Spliff durch die Schallmauer, das war in 3 Tagen da, ich war völlig überrascht. Das besonderst wichtige, es ist immer und immer wieder die exakt selbe Qualität. Ich hab jetzt schon so oft bestellt und kann das bestätigen. Die Auswahl wird immer größer und größer, ich bin Happy. Dann gibt es Cashback, du kriegst Geld von Spliff, wer da nicht zuschlägt ist wirklich selber Schuld. der Support ist immer noch voll auf Zack. Seit Mai bestelle ich regelmäßig, sogar in Vorkasse, alles Top.  ","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-09-26T16:50:23.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Zuverlääsig, schnell und gut","likes":0,"source":"Organic","dates":{"experiencedDate":"2025-09-02T00:00:00.000Z","publishedDate":"2025-09-26T16:50:23.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"686650212f24784db336b638","displayName":"Oliver Jünger","imageUrl":"https://user-images.trustpilot.com/686650212f24784db336b638/73x73.png","numberOfReviews":4,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":3,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"68b0226176b98335e774fcb5","filtered":false,"isPending":false,"text":"Habe dort vor einem Jahre etwas bestellt. Und keine Ware erhalten.Nach mehrmaligem schreiben an die Firma. Konnte sie mir trotz Vorauszahlungen nicht weiter helfen!!! Ich weiß  nicht warum so viele positive Bewertungen dabei sind??? Kann ich 0 nachvollziehen... . Definitiv und zu 1000% werde ich nie wieder dort bestellen und niemanden empfehlen!!! ","rating":1,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-08-28T11:33:21.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Habe dort vor einem Jahre etwas…","likes":1,"source":"Organic","dates":{"experiencedDate":"2025-08-27T00:00:00.000Z","publishedDate":"2025-08-28T11:33:21.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"68ae0c1b960069ceb813645f","displayName":"Ten ten Bibi","imageUrl":"https://user-images.trustpilot.com/68ae0c1b960069ceb813645f/73x73.png","numberOfReviews":4,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"687787ee0ceaf86e9cb6b55f","filtered":false,"isPending":false,"text":"Schnelle Lieferung! \nIch hatte erst kürzlich Liederprobleme, aber das LAG NICHT an dem tollen Spliff-Team!\nEs lag an meinem deutschen Logistiker DHL!\nOhne Rückmeldung weshalb der lieferstatus seit 5 Tagen nicht aktualisiert wurde, habe ich an Tag 6 meine Ware endlich abholen dürfen!\nDas Spliff-Team hat derweil zügig Hilfe angeboten aber auch zum Zeitpunkt der Rückmeldung es fragwürdig gefunden, dass die Lieferung pünktlich versendet und doch so lange brauchte, um in einer Packstation zu landen.\n\nDanke Spliff-Team!\nSuper Marke übrigens Magic Candy Sirup 🥳","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-07-16T13:07:26.000Z","reviewSourceName":"BasicLink","verificationSource":"invitation","verificationLevel":"invited","hasDachExclusion":false}},"title":"Schnelle Lieferung","likes":0,"source":"BasicLink","dates":{"experiencedDate":"2025-07-15T00:00:00.000Z","publishedDate":"2025-07-16T13:07:26.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"687787e520554d35213db51e","displayName":"bella n","imageUrl":"https://user-images.trustpilot.com/687787e520554d35213db51e/73x73.png","numberOfReviews":1,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"683e948ae8439dc58c10deaa","filtered":false,"isPending":false,"text":"meine erfahrung nach geht es nicht besser und schneller.top ware super netter service.\nbin hoch zufrieden und werde wieterhin bei spliff bestellen...vielen dank nochmal,gebe 10 punkte","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-06-03T08:22:02.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"meine erfahrung nach geht es nicht…besser und schneller","likes":0,"source":"Organic","dates":{"experiencedDate":"2025-05-30T00:00:00.000Z","publishedDate":"2025-06-03T08:22:02.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"58f0ca550000ff000a8d30b1","displayName":"ralf rombach","imageUrl":"","numberOfReviews":3,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"681315d0a4a75bced57191b7","filtered":false,"isPending":false,"text":"Ergänzung des ursprünglichen Textes: Nachdem Spliff zunächst nicht reagieert hatte, wurde in der Zwischenzeit eine umfangreiche Suche gestartet. Leider lässt sich der Standort der Sendung nicht mehr bestimmen, auch, weil zwei Transportdienstleister involviert sind. Heute hat mir Spliff die erneute Sendung oder vollständige Rückerstattung meiner Auslagen angeboten. Das nenne ich praktizierte Kundenorientierung. Deswegen Heraufstufung auf vier Sterne. Ursprünglicher Text v. 30.04.25: \"Eigentlich null Sterne. Ich habe Anfang April was bestellt. Als die Zahlung anfangs nicht korrekt war (zu wenig, weil ich ein Bonusangebot genutzt habe) wurde ich sofort von einer deutsch sprechenden Mitarbeiterin angerufen.\nSeitdem warte ich auf die Postsendung. Habe die Firma Spliff mehrfach angemailt, habe auch zweimal auf den AB dort gesprochen. Reaktion bisher: keine. Wenn die Kohle dort ist, scheint die Sache für die Firma erledigt zu sein, dann sind Kontaktversuche offenbar lästig und es wird nicht reagiert. Unterirdischer \"Service\", JAMAIS PLUS\"  ","rating":4,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-05-01T08:33:52.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Eigentlich null Sterne - korrigiert auf vier Sterne","likes":0,"source":"Organic","dates":{"experiencedDate":"2025-04-30T00:00:00.000Z","publishedDate":"2025-05-01T08:33:52.000Z","updatedDate":"2025-06-12T09:12:24.000Z","submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"52510d2000006400014f3916","displayName":"Rainer Gottlieb","imageUrl":"","numberOfReviews":1,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"67f8ce439bbcd91dbf8f7e91","filtered":false,"isPending":false,"text":"Ich habe nun schon das zweite mal bestellt und ich bin sehr zufrieden mit der Lieferung und der Qualität der Produkte. Wenn man ein Anliegen hat, wird sich auch gleich darum gekümmert. ","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-04-11T10:09:39.000Z","reviewSourceName":"BasicLink","verificationSource":"invitation","verificationLevel":"invited","hasDachExclusion":false}},"title":"Ich habe nun schon das zweite mal…","likes":0,"source":"BasicLink","dates":{"experiencedDate":"2025-04-11T00:00:00.000Z","publishedDate":"2025-04-11T10:09:39.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"5d84fbb239cf14c2726