":46},{"id":"67efd9024f8edc978263a8cd","order":47},{"id":"67d60a6742dff955d5c266db","order":48},{"id":"67f7b4b308c2244667ec1671","order":49},{"id":"693feb8e25fa62e56647e73e","order":50}],"sourceReviewIds":[]},"topicAiSummaries":[{"id":"65a8f486fe59a0421a2a19f2_de_product","businessUnitId":"65a8f486fe59a0421a2a19f2","modelVersion":"gemini-2.5-flash","updatedAt":"2026-03-15 03:18:36+00:00","lang":"de","topic":"product","status":"","summary":"Verbraucher finden die Produkte überwiegend positiv und sind mit der Qualität und Wirkung zufrieden. Viele loben die schnelle Lieferung und den guten Service, wobei Clara als stets erreichbar hervorgehoben wird. Besonders der Sirup und die Gummibärchen werden für ihre Wirkung und einfache Dosierung geschätzt. Einige Kunden berichten jedoch von einem bitteren Nachgeschmack beim Sirup oder gelegentlichen Fällen, in denen Produkte keine Wirkung zeigten oder nicht der Bestellung entsprachen.","order":1,"serviceReviewIds":[{"id":"698446f9ec4aefc02f477d6c","order":1},{"id":"696dda065fd8b422f79ff350","order":2},{"id":"695fc5cc1f25bd7787e15f5a","order":3},{"id":"69517d572b742c1f50b84dfc","order":4},{"id":"6949e44f1f042e678e62baaa","order":5},{"id":"691f29b6b97d424267af52ad","order":6},{"id":"68c0434030a357154bb1ff5a","order":7},{"id":"68b0226176b98335e774fcb5","order":8},{"id":"687f829ce96d48123652df13","order":9},{"id":"687b5fdfb06c5221012544aa","order":10},{"id":"687787ee0ceaf86e9cb6b55f","order":11},{"id":"686655e085810f38251ea231","order":12},{"id":"6856494515c9e80f84e4e57b","order":13},{"id":"682e2e755f66cda959a70c2a","order":14},{"id":"68285f1933dc54410b39c1cb","order":15},{"id":"6825faed407f1555597d0e24","order":16},{"id":"681315d0a4a75bced57191b7","order":17},{"id":"67ebc1724001207f69569dd5","order":18},{"id":"67e5c75f22e38694c45c92e8","order":19},{"id":"67d7f080d32e7a0a94ff86cb","order":20}]},{"id":"65a8f486fe59a0421a2a19f2_de_quality","businessUnitId":"65a8f486fe59a0421a2a19f2","modelVersion":"gemini-2.5-flash","updatedAt":"2026-03-15 03:18:36+00:00","lang":"de","topic":"quality","status":"","summary":"Kunden teilen positive Meinungen zur Produktqualität. Viele loben die konstant hohe Qualität der Produkte, die als erstklassig und astrein beschrieben wird. Einige heben besonders die \"THCX\"-Produkte und den Sirup hervor, die als sehr angenehm und wirkungsvoll empfunden werden. Allerdings gibt es auch vereinzelte Berichte über Produkte, die keine Wirkung zeigten, oder einen bitteren Nachgeschmack des Sirups, was zu Enttäuschung führte.","order":2,"serviceReviewIds":[{"id":"697c892e1c2d2768305dac3d","order":1},{"id":"696f6613ba894733ddfa440b","order":2},{"id":"696dda065fd8b422f79ff350","order":3},{"id":"69517d572b742c1f50b84dfc","order":4},{"id":"6949e44f1f042e678e62baaa","order":5},{"id":"693feb8e25fa62e56647e73e","order":6},{"id":"691f29b6b97d424267af52ad","order":7},{"id":"68d6a82fd6f5a8d128c32aa1","order":8},{"id":"68b202675e8f48a1a945c12b","order":9},{"id":"687b5fdfb06c5221012544aa","order":10},{"id":"683320f8deb91026bd6d7b00","order":11},{"id":"682e2e755f66cda959a70c2a","order":12},{"id":"68285f1933dc54410b39c1cb","order":13},{"id":"6825faed407f1555597d0e24","order":14},{"id":"67f7b4b308c2244667ec1671","order":15},{"id":"67f3e47fb057a865d91c0484","order":16},{"id":"67f128e9029057785c1eff65","order":17},{"id":"67ee5267828a3b13657c3bf7","order":18},{"id":"67e5c75f22e38694c45c92e8","order":19},{"id":"67d7f080d32e7a0a94ff86cb","order":20}]},{"id":"65a8f486fe59a0421a2a19f2_de_delivery_service","businessUnitId":"65a8f486fe59a0421a2a19f2","modelVersion":"gemini-2.5-flash","updatedAt":"2026-03-15 03:18:36+00:00","lang":"de","topic":"delivery_service","status":"","summary":"Kunden verzeichnen durchweg positive Erfahrungen mit dem Lieferservice. Viele loben die schnelle und zuverlässige Lieferung, wobei einige Bestellungen innerhalb von drei bis vier Tagen ankamen. Verbraucher schätzen auch den schnellen und kundenorientierten Support bei Lieferproblemen, wie verlorenen Paketen, die umgehend ersetzt wurden. Trotz gelegentlicher Schwierigkeiten mit externen Logistikpartnern, die zu Verzögerungen führten, sind die Kunden insgesamt sehr zufrieden mit dem Service und der Qualität der Produkte.","order":3,"serviceReviewIds":[{"id":"698446f9ec4aefc02f477d6c","order":1},{"id":"697c892e1c2d2768305dac3d","order":2},{"id":"69714c603d8c4ccd488ebd39","order":3},{"id":"695fc5cc1f25bd7787e15f5a","order":4},{"id":"6949e44f1f042e678e62baaa","order":5},{"id":"6911142b30a74a92f15cda04","order":6},{"id":"69087dd695eadb340ac3062a","order":7},{"id":"68d6a82fd6f5a8d128c32aa1","order":8},{"id":"687b5fdfb06c5221012544aa","order":9},{"id":"687787ee0ceaf86e9cb6b55f","order":10},{"id":"686655e085810f38251ea231","order":11},{"id":"6856494515c9e80f84e4e57b","order":12},{"id":"6821e8c0ac95db9faf211cdc","order":13},{"id":"681315d0a4a75bced57191b7","order":14},{"id":"67f6b74ffb21415af6004a28","order":15},{"id":"67f128e9029057785c1eff65","order":16},{"id":"67ebdf19a3d8f6cda60f9e94","order":17},{"id":"67ea4a2c7e55827507f7e7d3","order":18},{"id":"67dc9313ed6139eed8668d60","order":19},{"id":"67d7f080d32e7a0a94ff86cb","order":20}]},{"id":"65a8f486fe59a0421a2a19f2_de_order","businessUnitId":"65a8f486fe59a0421a2a19f2","modelVersion":"gemini-2.5-flash","updatedAt":"2026-03-15 03:18:36+00:00","lang":"de","topic":"order","status":"","summary":"Menschen berichten von gemischten Erfahrungen mit dem Bestellvorgang. Einige Kunden loben die schnelle und problemlose Abwicklung der Bestellung sowie den super Kundenservice, der bei Lieferproblemen schnell und hilfsbereit reagierte. Andere Verbraucher äußern jedoch Enttäuschung über mangelnde Wirkung der Produkte, fehlerhafte Bestellbearbeitung oder Lieferprobleme, bei denen Pakete nicht zugestellt werden konnten. Es gab auch Fälle, in denen falsche Artikel geliefert wurden, wie ein Joint statt bestellter Gummibärchen.","order":4,"serviceReviewIds":[{"id":"697c892e1c2d2768305dac3d","order":1},{"id":"695fc5cc1f25bd7787e15f5a","order":2},{"id":"69517d572b74