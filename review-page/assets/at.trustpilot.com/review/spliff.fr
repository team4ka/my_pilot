vitation","verificationLevel":"verified","hasDachExclusion":false}},"title":"Ware kommt flott ist toll verpackt und…","likes":0,"source":"WooCommerce","dates":{"experiencedDate":"2025-03-20T00:00:00.000Z","publishedDate":"2025-04-03T11:18:31.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"65eb629e44eae60012aba354","displayName":"Bianca Bajrami","imageUrl":"","numberOfReviews":2,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"67ebdf19a3d8f6cda60f9e94","filtered":false,"isPending":false,"text":"Trotz ein paar Kiefer Problemen durch den deutschen lieferdienst was nichts mit dem Shop zu tun hat ist alles super und reibungslos gelaufen der Service war super und meine Bestellung unschlagbar ","rating":5,"labels":{"merged":null,"verification":{"isVerified":true,"createdDateTime":"2025-04-01T14:42:01.000Z","reviewSourceName":"WooCommerce","verificationSource":"invitation","verificationLevel":"verified","hasDachExclusion":false}},"title":"Service ","likes":0,"source":"WooCommerce","dates":{"experiencedDate":"2025-03-18T00:00:00.000Z","publishedDate":"2025-04-01T14:42:01.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"67ebdf1774626a557153473c","displayName":"Nick","imageUrl":"","numberOfReviews":1,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"67ebc1724001207f69569dd5","filtered":false,"isPending":false,"text":"Ich hatte Gummibärchen bestellt, da ich nicht rauche. Ich bekam auch Gummibärchen. Allerdings viel weniger als gedacht. Stattdessen war ein fertiger Joint dabei, den ich nicht bestellt hatte und auch nicht benutzen kann, da ich ja -wie gesagt-nicht rauche. Schade.","rating":4,"labels":{"merged":null,"verification":{"isVerified":true,"createdDateTime":"2025-04-01T12:35:30.000Z","reviewSourceName":"WooCommerce","verificationSource":"invitation","verificationLevel":"verified","hasDachExclusion":false}},"title":"Ich hatte Gummibärchen bestellt","likes":0,"source":"WooCommerce","dates":{"experiencedDate":"2025-03-18T00:00:00.000Z","publishedDate":"2025-04-01T12:35:30.000Z","updatedDate":"2025-04-01T13:24:23.000Z","submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"6557c1d0d48df20012a8ede7","displayName":"Fielz","imageUrl":"","numberOfReviews":3,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"67d7f080d32e7a0a94ff86cb","filtered":false,"isPending":false,"text":"Richtig gut. Je nach Dosis (1/4 - 1/2 - 3/4 oder ein ganzes Bärchen) alles dabei von einfach nur relaxed bis mehr als chillig zu klar und super angenehm breit. Klare Kaufempfehlung. Viel besser zu dosieren als rauchen und ein ganz anderes, viel bewussterer und klarer Zustand. Bestellen definitiv wieder. Ablauf war gut, Lieferung aus FR auch akzeptabel was die Zeit angeht.","rating":5,"labels":{"merged":null,"verification":{"isVerified":true,"createdDateTime":"2025-03-17T11:50:56.000Z","reviewSourceName":"WooCommerce","verificationSource":"invitation","verificationLevel":"verified","hasDachExclusion":false}},"title":"Klare Empfehlung","likes":0,"source":"WooCommerce","dates":{"experiencedDate":"2025-03-16T00:00:00.000Z","publishedDate":"2025-03-17T11:50:56.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"67d7f07f7062e8cc0ed5965b","displayName":"J. E.","imageUrl":"","numberOfReviews":1,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null}]],["65a8f486fe59a0421a2a19f2_de_staff",[{"id":"698446f9ec4aefc02f477d6c","filtered":false,"isPending":false,"text":"Habe weitere Produckte getestet und kann nur Sagen Wow macht weiter so schnelle lieferung Top service und ein großer Dank geht an Clara die immer erreichbar ist bei allen fragen","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2026-02-05T09:30:01.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Habe weitere Produckte getestet und…","likes":0,"source":"Organic","dates":{"experiencedDate":"2026-02-05T00:00:00.000Z","publishedDate":"2026-02-05T09:30:01.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"6959697431cbb9360b883530","displayName":"Enrico Mirek Willing","imageUrl":"https://user-images.trustpilot.com/6959697431cbb9360b883530/73x73.png","numberOfReviews":5,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":{"message":"Vielen herzlichen Dank für Ihr großartiges Feedback! ✨\n\nWir freuen uns sehr, dass Ihre Erfahrung Ihren Erwartungen entsprochen hat.\n\nEin großes Dankeschön auch für Ihre besondere Erwähnung von Clara: Wir werden ihr Ihre Nachricht selbstverständlich weiterleiten – sie wird sich sehr über Ihre Worte freuen.\n\nWir freuen uns darauf, Sie bald wieder bedienen zu dürfen! 💚\n\nDas Spliff-Team","publishedDate":"2026-02-18T09:01:19.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":2,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"697c892e1c2d2768305dac3d","filtered":false,"isPending":false,"text":"Seit Mai 2025 bestelle ich jeden Monat bei Spliff. Die Qualität ist der Hammer und immer exakt gleich gut. Das Produkt kommt in edlen schwarzen Tüten die luftdicht verschweißt sind.Der Support hat mich noch nie hängen lassen, eine Antwort vom Spliffsupport dauert zwischen 2-3 Stunden und man nimmt sich den Problemen der Kunden freundlich und lösungswillig an. Erst jetzt hat Spliff auf die Paketzusteller reagiert und einen neuen Paketzusteller genommen. Spliff bleibt die Nr. 1 für mich, Preis- Leistung ist auch super gut. Wer nicht bei Spliff bestellt ist selber schuld. Alle Pakete sind immer angekommen und so manches Paket hat mich echt vom Sockel gehauen, viele schöne Extras waren schon dabei. Man merkt das die Mitarbeiter es lieben was sie da tun und man wird als Kunde geschätzt. Immer wieder neue Produkte die einem die Entscheidung echt schwer macht. Ich bin zu 100% zufrieden mit Spliff, wenn der neue Paketzusteller hält was er verspricht gibt es nichts mehr zu motzen.\nDanke Spliff für eure tolle Arbeit und nein ich bekomme kein Schmiergeld von Spliff, das ist meine Erfahrung mit der besten Seite der Welt.  ","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2026-01-30T12:34:22.000Z","reviewSourceName":"BasicLink","verificationSource":"invitation","verificationLevel":"invited","hasDachExclusion":false}},"title":"SPLIFF?- Genau mein DIng","likes":0,"source":"BasicLink","dates":{"experiencedDate":"2026-01-30T00:00:00.000Z","publishedDate":"2026-01-30T12:34:22.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"686650212f24784db336b638","displayName":"Oliver Jünger","imageUrl":"https://user-images.trustpilot.com/686650212f24784db336b638/73x73.png","numberOfReviews":4,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":{"message":"Vielen, vielen Dank für dieses super ausführliche Feedback 🙏\nZu wissen, dass du seit Mai 2025 jeden Monat bestellst und dass dich Qualität, Packaging, unser Kundenservice und die kleinen Extras so überzeugen, bedeutet uns wirklich viel. ✨\n\nWir haben den Versanddienstleister tatsächlich gewechselt, um die Lieferprobleme zu lösen – und wir werden alles dafür tun, dass es jetzt endlich einwandfrei läuft.\nDanke für dein Vertrauen – es kommen noch einige richtig starke Neuheiten 😄\n\nDas Spliff-team","publishedDate":"2026-02-04T08:49:41.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":3,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"696f6613ba894733ddfa440b","filtered":false,"isPending":false,"text":"Super Support,  antworten sofort und auch Hilfreich. \n\nDie Produkte sind Erstklassig , werde hier öfter bestellen. ","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2026-01-20T13:25:07.000Z","reviewSourceName":"BasicLink","verificationSource":"invitation","verificationLevel":"invited","hasDachExclusion":false}},"title":"Super Support und Super Produkte","likes":0,"source":"BasicLink","dates":{"experiencedDate":"2026-01-19T00:00:00.000Z","publishedDate":"2026-01-20T13:25:07.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"696f660bc37c28a2b718283a","displayName":"Moris Mohs","imageUrl":"https://user-images.trustpilot.com/696f660bc37c28a2b718283a/73x73.png","numberOfReviews":1,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":{"message":"Vielen herzlichen Dank für Ihre positive Rückmeldung! Es freut uns sehr, dass Sie mit unserem Support und der Qualität unserer Produkte so zufrieden sind. Wir freuen uns darauf, Sie bald wieder bei uns begrüßen zu dürfen 😊\n\nDas Spliff-Team","publishedDate":"2026-01-22T16:04:24.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"696dda065fd8b422f79ff350","filtered":false,"isPending":false,"text":"Spliff ist genial. Ich bin sehr glücklich, dieses aus Zufall im Internet gefunden zu haben. Extrem zuverlässig :-) Clara kommuniziert immer sehr freundlich, kompetent und zeitnah. Gute Qualität, super Verpackung. Diskret. Gesund. Hilft bei körperlichen Schmerzen .Ein tolles Team - Danke :-)","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2026-01-19T09:15:18.000Z","reviewSourceName":"BasicLink","verificationSource":"invitation","verificationLevel":"invited","hasDachExclusion":false}},"title":"Spliff ist genial","likes":0,"source":"BasicLink","dates":{"experiencedDate":"2026-01-14T00:00:00.000Z","publishedDate":"2026-01-19T09:15:18.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"696dd9f84698843c3f69486a","displayName":"Colette Von Der Goltz-Koydl","imageUrl":"https://user-images.trustpilot.com/696dd9f84698843c3f69486a/73x73.png","numberOfReviews":1,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":{"message":"Vielen Dank für dieses großartige Feedback!\nWir freuen uns sehr, dass Sie Spliff entdeckt haben und dass unsere Produkte und unsere Betreuung Ihren Erwartungen entsprochen haben.\nDas gesamte Team, insbesondere Clara, bedankt sich für Ihre sehr ermutigenden Worte.\nWir freuen uns darauf, Sie wieder zu begleiten 🌿","publishedDate":"2026-01-22T16:02:02.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"69517d572b742c1f50b84dfc","filtered":false,"isPending":false,"text":"Ich habe viel erlebt mit „Clara“.  Ich habe immer Antwort bekommen, meistens nach einem Tag aber auch zwei und auch schon längere Zeit aber es hat sich immer jemand gemeldet, um mir und meiner Bestellung zu helfen. Manche schreiben hier, die Gummibärchen würden nicht knallen, finde ich auch leider, bei jeder meiner Bestellungen ist immer son Gummibärchen dabei, würde ich niemals bestellen, haben null Effekt.. Was ich immer bestelle ist dieser Sirum 300 in verschiedenen Geschmacksrichtungen, wobei der bittere Nachgang bei jedem Schluck schon echt bitter ist. Der Situp knallt gut, bin eigentlich leidenschaftliche kifferin, habe aber mit rauchen aufgehört. Ich bin im Training.wie man so schön sagt.. trotzdem knallt der Sirup sehr gut, ich finde nur irgendwie leider nicht so lange so 3 Stunden aber das mag an der EU und deren Bevormundung und der runter Regulierung liegen.","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-12-28T20:56:23.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Ich habe viel erlebt mit „Clara“","likes":0,"source":"Organic","dates":{"experiencedDate":"2025-12-28T00:00:00.000Z","publishedDate":"2025-12-28T20:56:23.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"61e82b58317986001258fdec","displayName":"Itz_akari-Chan UWU","imageUrl":"","numberOfReviews":5,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":{"message":"Guten Tag,\nvielen Dank für Ihr ausführliches Feedback und Ihre positiven Worte zu Ihrem Austausch mit unserem Service – die Qualität unseres Kundenservices ist für uns von zentraler Bedeutung.\nBezüglich der Gummies haben wir eine Charge identifiziert, die in Bezug auf die Wirkung nicht unseren Erwartungen entsprach. Dieses Problem wurde inzwischen behoben, und die aktuellen Chargen entsprechen wieder vollständig unseren Standards.\nEs freut uns sehr, dass Ihnen die Sirupe gefallen. Der leicht bittere Geschmack ist auf die hohe THC-Konzentration zurückzuführen. Die kürzere Wirkungsdauer erklärt sich durch die schnelle Aufnahme aufgrund der Verdauung und der flüssigen Produktform.\nWenn Sie eine länger anhaltende Wirkung suchen, empfehlen wir Ihnen, unsere Brownies zu probieren, deren langsamere Aufnahme in der Regel eine Wirkungsdauer von 4 bis 5 Stunden ermöglicht.\nVielen Dank nochmals für Ihr Vertrauen.\n\nIhr Spliff-Team","publishedDate":"2026-01-15T14:50:54.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"68d6a82fd6f5a8d128c32aa1","filtered":false,"isPending":false,"text":"Diesmal ist Spliff durch die Schallmauer, das war in 3 Tagen da, ich war völlig überrascht. Das besonderst wichtige, es ist immer und immer wieder die exakt selbe Qualität. Ich hab jetzt schon so oft bestellt und kann das bestätigen. Die Auswahl wird immer größer und größer, ich bin Happy. Dann gibt es Cashback, du kriegst Geld von Spliff, wer da nicht zuschlägt ist wirklich selber Schuld. der Support ist immer noch voll auf Zack. Seit Mai bestelle ich regelmäßig, sogar in Vorkasse, alles Top.  ","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-09-26T16:50:23.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Zuverlääsig, schnell und gut","likes":0,"source":"Organic","dates":{"experiencedDate":"2025-09-02T00:00:00.000Z","publishedDate":"2025-09-26T16:50:23.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"686650212f24784db336b638","displayName":"Oliver Jünger","imageUrl":"https://user-images.trustpilot.com/686650212f24784db336b638/73x73.png","numberOfReviews":4,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":3,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"687787ee0ceaf86e9cb6b55f","filtered":false,"isPending":false,"text":"Schnelle Lieferung! \nIch hatte erst kürzlich Liederprobleme, aber das LAG NICHT an dem tollen Spliff-Team!\nEs lag an meinem deutschen Logistiker DHL!\nOhne Rückmeldung weshalb der lieferstatus seit 5 Tagen nicht aktualisiert wurde, habe ich an Tag 6 meine Ware endlich abholen dürfen!\nDas Spliff-Team hat derweil zügig Hilfe angeboten aber auch zum Zeitpunkt der Rückmeldung es fragwürdig gefunden, dass die Lieferung pünktlich versendet und doch so lange brauchte, um in einer Packstation zu landen.\n\nDanke Spliff-Team!\nSuper Marke übrigens Magic Candy Sirup 🥳","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-07-16T13:07:26.000Z","reviewSourceName":"BasicLink","verificationSource":"invitation","verificationLevel":"invited","hasDachExclusion":false}},"title":"Schnelle Lieferung","likes":0,"source":"BasicLink","dates":{"experiencedDate":"2025-07-15T00:00:00.000Z","publishedDate":"2025-07-16T13:07:26.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"687787e520554d35213db51e","displayName":"bella n","imageUrl":"https://user-images.trustpilot.com/687787e520554d35213db51e/73x73.png","numberOfReviews":1,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"686655e085810f38251ea231","filtered":false,"isPending":false,"text":"Ich hab mich an den Support gewendet, per E-Mail, keine 1,5 Stunden später hatte ich eine Antwort, das Spliff nicht antwortet ist ein übles \"Schreckgespenst\". Auf erneute Frage, hatte ich noch schneller eine Antwort, ca. 1 Stunde. Ich war freundlich, das Spliff Team war auch sehr freundlich, erklärte mir wo es hängen könnte, denn ab der Post, selbst auf dem Jupiter, muss Spliff bei der \"Post\" nachfragen und kann dann wieder informieren. Müsste man verstehen können.\nGrüße an das Spliff- Team, ich bin begeistert. \nZur Sendung, da gehören dafür 5 Sterne hintendran, kauf ich auf jeden Fall wieder ein, wenn es kurz hakt, cool bleiben ;) \nTHX SPLIFF  ","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-07-03T12:05:20.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Schnellster Support ever","likes":0,"source":"Organic","dates":{"experiencedDate":"2025-07-03T00:00:00.000Z","publishedDate":"2025-07-03T12:05:20.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"686650212f24784db336b638","displayName":"Oliver Jünger","imageUrl":"https://user-images.trustpilot.com/686650212f24784db336b638/73x73.png","numberOfReviews":4,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":3,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"68417779392e79b700ef242b","filtered":false,"isPending":false,"text":"Top Qualität\nClara vom Kundenservice ist tip top\nWärmstens zu empfehlen\nPreis/ Leistung... großartig ","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-06-05T12:54:49.000Z","reviewSourceName":"BasicLink","verificationSource":"invitation","verificationLevel":"invited","hasDachExclusion":false}},"title":"Top Qualität","likes":0,"source":"BasicLink","dates":{"experiencedDate":"2025-05-15T00:00:00.000Z","publishedDate":"2025-06-05T12:54:49.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"67ebb10c05c9024d815961d6","displayName":"Andreas Ide","imageUrl":"https://user-images.trustpilot.com/67ebb10c05c9024d815961d6/73x73.png","numberOfReviews":1,"countryCode":"DE","hasImage":true,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"681315d0a4a75bced57191b7","filtered":false,"isPending":false,"text":"Ergänzung des ursprünglichen Textes: Nachdem Spliff zunächst nicht reagieert hatte, wurde in der Zwischenzeit eine umfangreiche Suche gestartet. Leider lässt sich der Standort der Sendung nicht mehr bestimmen, auch, weil zwei Transportdienstleister involviert sind. Heute hat mir Spliff die erneute Sendung oder vollständige Rückerstattung meiner Auslagen angeboten. Das nenne ich praktizierte Kundenorientierung. Deswegen Heraufstufung auf vier Sterne. Ursprünglicher Text v. 30.04.25: \"Eigentlich null Sterne. Ich habe Anfang April was bestellt. Als die Zahlung anfangs nicht korrekt war (zu wenig, weil ich ein Bonusangebot genutzt habe) wurde ich sofort von einer deutsch sprechenden Mitarbeiterin angerufen.\nSeitdem warte ich auf die Postsendung. Habe die Firma Spliff mehrfach angemailt, habe auch zweimal auf den AB dort gesprochen. Reaktion bisher: keine. Wenn die Kohle dort ist, scheint die Sache für die Firma erledigt zu sein, dann sind Kontaktversuche offenbar lästig und es wird nicht reagiert. Unterirdischer \"Service\", JAMAIS PLUS\"  ","rating":4,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-05-01T08:33:52.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Eigentlich null Sterne - korrigiert auf vier Sterne","likes":0,"source":"Organic","dates":{"experiencedDate":"2025-04-30T00:00:00.000Z","publishedDate":"2025-05-01T08:33:52.000Z","updatedDate":"2025-06-12T09:12:24.000Z","submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"52510d2000006400014f3916","displayName":"Rainer Gottlieb","imageUrl":"","numberOfReviews":1,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"de","location":null},{"id":"67d60a6742dff955d5c266db","filtered":false,"isPending":false,"text":"hey ho.\n\nschneller und sehr netter service. zudem eine gute qualität. ich gebe euch eine 5,5 von 5 🙃","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-03-16T01:16:55.000Z","reviewSourceName":"Organic","verif