998a87cb9bf29f82550f4","filtered":false,"isPending":false,"text":"Prodotti buonissimi con consegna veloce e tracciata. Uno dei migliori nel campo!!","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2024-09-05T13:40:24.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Prodotti buonissimi con consegna veloce…","likes":1,"source":"Organic","dates":{"experiencedDate":"2024-09-05T00:00:00.000Z","publishedDate":"2024-09-05T13:40:24.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"5e6ce0f0dffcf749578ad4d8","displayName":"Andrea Carella","imageUrl":"https://user-images.trustpilot.com/5e6ce0f0dffcf749578ad4d8/73x73.png","numberOfReviews":5,"countryCode":"IT","hasImage":true,"isVerified":true},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"it","location":null},{"id":"668a404977dcc03c1dcc9ae9","filtered":false,"isPending":false,"text":"Ottima qualità e consegna veloce, buona la varietà di prodotti.","rating":4,"labels":{"merged":null,"verification":{"isVerified":true,"createdDateTime":"2024-07-07T09:14:17.000Z","reviewSourceName":"Shopify","verificationSource":"invitation","verificationLevel":"verified","hasDachExclusion":false}},"title":"Ottima qualità e consegna veloce","likes":0,"source":"Shopify","dates":{"experiencedDate":"2024-06-27T00:00:00.000Z","publishedDate":"2024-07-07T09:14:17.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"5f1f11dcfd29d34e4152b551","displayName":"Federico","imageUrl":"","numberOfReviews":3,"countryCode":"DE","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"it","location":null},{"id":"665b1eee2cc0e3fb1ca39dab","filtered":false,"isPending":false,"text":"Spedizione lenta e prodotto pessimo.\nTutti che parlano di questo Thcp che ti sballa,ma non fa nulla,sapore orribile,sconsiglio","rating":1,"labels":{"merged":null,"verification":{"isVerified":true,"createdDateTime":"2024-06-01T15:15:26.000Z","reviewSourceName":"Shopify","verificationSource":"invitation","verificationLevel":"verified","hasDachExclusion":false}},"title":"Spedizione lenta e prodotto pessimo.","likes":0,"source":"Shopify","dates":{"experiencedDate":"2024-05-22T00:00:00.000Z","publishedDate":"2024-06-01T15:15:26.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"665b1eed3a3109945661abe2","displayName":"Luck","imageUrl":"","numberOfReviews":2,"countryCode":"IT","hasImage":false,"isVerified":false},"reply":{"message":"Ciao, grazie per il tuo feedback.\nPurtroppo non siamo responsabili dei tempi di consegna, posso garantire che spediamo i pacchi tutti i giorni entro le ore 12:00.\nPer quanto riguarda il THCP, mi dispiace apprendere che la tua esperienza non è stata positiva. Puoi contattarmi a clara@spliff.fr per discuterne e trovare una soluzione. Bella giornata a te.\n\nChiara.","publishedDate":"2024-06-04T09:35:13.000Z","updatedDate":null},"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"it","location":null}],"relevantReviews":[],"aiSummaryReviews":[],"topicAiSummaryReviews":null,"products":[],"filters":{"hasActiveFilters":false,"totalNumberOfReviews":464,"totalNumberOfFilteredReviews":9,"pagination":{"currentPage":1,"perPage":20,"totalCount":9,"totalPages":1},"selected":{"languages":"it","date":null,"stars":null,"topics":null,"search":null,"locationId":null,"sort":"recency","verified":false,"replies":false},"reviewStatistics":{"hasMultipleLanguages":true,"reviewLanguages":[{"isoCode":"all","reviewCount":464,"displayName":"all"},{"isoCode":"de","reviewCount":302,"displayName":"Deutsch"},{"isoCode":"en","