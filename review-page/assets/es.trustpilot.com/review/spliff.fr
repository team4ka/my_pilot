ustpilot.com/review/spliff.fr"}}]},{"@type":"ImageObject","@id":"https://www.trustpilot.com/#/schema/ImageObject/spliff.fr","url":"https://s3-eu-west-1.amazonaws.com/tpd/logos/65a8f486fe59a0421a2a19f2/0x0.png","contentUrl":"https://s3-eu-west-1.amazonaws.com/tpd/logos/65a8f486fe59a0421a2a19f2/0x0.png"},{"@type":"LocalBusiness","@id":"https://www.trustpilot.com/#/schema/Organization/spliff.fr","url":"https://es.trustpilot.com/review/spliff.fr","sameAs":"https://spliff.fr","name":"Spliff","description":"Spliff offre une expérience exceptionnelle dans le monde du CBD récréatif. Des fleurs de qualité premium et des produits décontractés qui font de chaque moment une escapade chill. 🌿💨 #SpliffVibes","email":"info@spliff.fr","telephone":"+33 4 65 84 54 28","address":{"@type":"PostalAddress","streetAddress":"42 rue de l'aiguillerie","addressLocality":"Montpellier","addressCountry":"FR","postalCode":"34000"},"image":{"@id":"https://www.trustpilot.com/#/schema/ImageObject/spliff.fr"},"aggregateRating":{"@type":"AggregateRating","bestRating":"5","worstRating":"1","ratingValue":"4.2","reviewCount":"512"},"review":[{"@id":"https://www.trustpilot.com/#/schema/Review/spliff.fr/688a725c01f91e68584943b4"},{"@id":"https://www.trustpilot.com/#/schema/Review/spliff.fr/6750eec073969a8ba87e4f1c"}]},{"@type":"Review","@id":"https://www.trustpilot.com/#/schema/Review/spliff.fr/688a725c01f91e68584943b4","itemReviewed":{"@id":"https://www.trustpilot.com/#/schema/Organization/spliff.fr"},"author":{"@type":"Person","name":"Manolito","url":"https://es.trustpilot.com/users/688a723e9600695714ec8707/"},"datePublished":"2025-07-30T21:28:28.000Z","headline":"Maravilloso","reviewBody":"Maravilloso ","reviewRating":{"@type":"Rating","bestRating":"5","worstRating":"1","ratingValue":"5"},"publisher":{"@id":"https://www.trustpilot.com/#/schema/Organization/1"},"inLanguage":"es"},{"@type":"Review","@id":"https://www.trustpilot.com/#/schema/Review/spliff.fr/6750eec073969a8ba87e4f1c","itemReviewed":{"@id":"https://www.trustpilot.com/#/schema/Organization/spliff.fr"},"author":{"@type":"Person","name":"customer","url":"https://es.trustpilot.com/users/6183f70c4a974d0012c1511f/"},"datePublished":"2024-12-05T02:07:28.000Z","headline":"Pedido 13242","reviewBody":"10 días laborables en llegar el pedido, tal vez para los que residan fuera de Francia los tiempos sean un hándicap para ser clientes recurrentes.Pedí un total de 9 hash, he de decir que la ejecución es bastante buena pero la intensidad del sabor y el olor es bastante flojo, las flores de cbd no suelen tener la potencia de sus primas Thc pero en este sentido las hay mejores. Los niveles de cbd o cbn no corresponden con el efecto, tal vez una analítica con valores de sus cannabinoides daría más fiabilidad al cliente y caché a la empresa.Los que más me gustaron.. -Black cristal, de textura dura pero es auténtica resina, poco sabor/olor y efecto muy suave para su 85% de Cbn-Static runtz, aunque llegó arena el sabor y olor es rico aunque también flojo, de efecto muy suave también.Los que menos me gustaron...GMO Y static hash, malos, si fumas 1gr dan náuseas y cierto malestar, no recomiendo además el efecto es inexistente.Mantengo las 3 estrellas por tiempos de envío y flores, hay proveedores con productos que supuestamente continenen menos cbd y hacen más efecto, además tienen sabores y olores más potentes. Aún así no están mal pero no valen su precio, no creo que repita. ","reviewRating":{"@type":"Rating","bestRating":"5","worstRating":"1","ratingValue":"3"},"publisher":{"@id":"https://www.trustpilot.com/#/schema/Organization/1"},"inLanguage":"es"}]}</script><script type="application/ld+json" data-business-unit-json-ld-dataset="true">{"@context":["https://schema.org",{"csvw":"http://www.w3.org/ns/csvw#"}],"@graph":{"@type":"Dataset","@id":"https://www.trustpilot.com/#/schema/DataSet/spliff.fr/1","name":"Spliff","description":"Gráfico de la distribución las valoraciones de Spliff. Fuente: Trustpilot.","publisher":{"@id