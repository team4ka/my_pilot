sClaimed":true,"isClosed":false,"isTemporarilyClosed":false,"locationsCount":0,"isCollectingReviews":true,"verification":{"verifiedByGoogle":false,"verifiedPaymentMethod":true,"verifiedUserIdentity":true},"hasCollectedIncentivisedReviews":false,"consumerAlert":null,"consumerAlerts":[],"isMerged":false,"contactInfo":{"email":"info@spliff.fr","address":"42 rue de l'aiguillerie","city":"Montpellier","country":"FR","phone":"+33 4 65 84 54 28","zipCode":"34000"},"activity":{"isUsingPaidFeatures":true,"hasSubscription":true,"isAskingForReviews":true,"claimedDate":"2024-01-18T09:52:57.000Z","isClaimed":true,"previouslyClaimed":true,"replyBehavior":{"averageDaysToReply":58,"lastReplyToNegativeReview":"2026-03-18 09:01:33 UTC","negativeReviewsWithRepliesCount":9,"replyPercentage":45,"totalNegativeReviewsCount":20},"verification":{"verifiedByGoogle":false,"verifiedPaymentMethod":true,"verifiedUserIdentity":true},"hasBusinessUnitMergeHistory":false,"isUsingAIResponses":false},"hasCustomHeaderSetting":true,"hasPromotionSetting":false},"reviews":[{"id":"688a725c01f91e68584943b4","filtered":false,"isPending":false,"text":"Maravilloso ","rating":5,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2025-07-30T21:28:28.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Maravilloso","likes":0,"source":"Organic","dates":{"experiencedDate":"2025-07-29T00:00:00.000Z","publishedDate":"2025-07-30T21:28:28.000Z","updatedDate":null,"submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"688a723e9600695714ec8707","displayName":"Manolito","imageUrl":"","numberOfReviews":1,"countryCode":"ES","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"es","location":null},{"id":"6750eec073969a8ba87e4f1c","filtered":false,"isPending":false,"text":"10 días laborables en llegar el pedido, tal vez para los que residan fuera de Francia los tiempos sean un hándicap para ser clientes recurrentes.\nPedí un total de 9 hash, he de decir que la ejecución es bastante buena pero la intensidad del sabor y el olor es bastante flojo, las flores de cbd no suelen tener la potencia de sus primas Thc pero en este sentido las hay mejores. Los niveles de cbd o cbn no corresponden con el efecto, tal vez una analítica con valores de sus cannabinoides daría más fiabilidad al cliente y caché a la empresa.\nLos que más me gustaron.. \n-Black cristal, de textura dura pero es auténtica resina, poco sabor/olor y efecto muy suave para su 85% de Cbn\n-Static runtz, aunque llegó arena el sabor y olor es rico aunque también flojo, de efecto muy suave también.\nLos que menos me gustaron...\nGMO Y static hash, malos, si fumas 1gr dan náuseas y cierto malestar, no recomiendo además el efecto es inexistente.\nMantengo las 3 estrellas por tiempos de envío y flores, hay proveedores con productos que supuestamente continenen menos cbd y hacen más efecto, además tienen sabores y olores más potentes. Aún así no están mal pero no valen su precio, no creo que repita.\n\n ","rating":3,"labels":{"merged":null,"verification":{"isVerified":false,"createdDateTime":"2024-12-05T02:07:28.000Z","reviewSourceName":"Organic","verificationSource":"invitation","verificationLevel":"not-verified","hasDachExclusion":false}},"title":"Pedido 13242","likes":0,"source":"Organic","dates":{"experiencedDate":"2024-12-05T00:00:00.000Z","publishedDate":"2024-12-05T02:07:28.000Z","updatedDate":"2024-12-16T15:32:37.000Z","submittedDate":null},"report":null,"hasUnhandledReports":false,"consumer":{"id":"6183f70c4a974d0012c1511f","displayName":"customer","imageUrl":"","numberOfReviews":7,"countryCode":"ES","hasImage":false,"isVerified":false},"reply":null,"consumersReviewCountOnSameDomain":1,"consumersReviewCountOnSameLocation":null,"productReviews":[],"language":"es","location":null}],"rel