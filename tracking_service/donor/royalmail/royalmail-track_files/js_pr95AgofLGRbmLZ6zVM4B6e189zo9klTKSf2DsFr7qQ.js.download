            $("main .layout-content .royalmailmyaccountpageheaderparent").css('z-index', 'unset');
            $("footer").css("z-index", "unset");
            $(".content-bottom-wrapper").css("z-index", "unset");
            $('.bingsearchresults').css('z-index', 'unset');
            $('#overlayrmgmenusearch').css('display', 'none');
            $('.rmgheader').css('box-shadow', '');
          });

          if ($(window).width() >= 1200) {

            $( '.menu li div.mobtab-1 a' ).addClass( "menu-caret icon-down-arrow");
            $( '.menu li div.mobtab-2 a' ).addClass( "menu-caret icon-down-arrow");
            $( '.menu li div.mobtab-3 a' ).addClass( "menu-caret icon-down-arrow");
            $('.toolbar-oriented .toolbar-bar').css('z-index', '999');

            $( ".menu li.parent-item-1" ).hover(function() {
                $('.mobtab-1 .menu-caret').addClass( "icon-up-arrow " );
                $('.mobtab-1 .menu-caret').removeClass( "icon-down-arrow " );
                $('head').append('<style>.rmgheader .menu li a.is-active:before{box-shadow:none;}</style>');
                $('head').append('<style>.rmgheader .menu-primary-menu .primary-nav__menu-item--active-trail:before{box-shadow:none!important;}</style>');
              }, function() {
                $('.mobtab-1 .menu-caret').removeClass( "icon-up-arrow " );
                $('.mobtab-1 .menu-caret').addClass( "icon-down-arrow " );
                $('head').append('<style>.rmgheader .menu li a.is-active:before{box-shadow:0 25px 0 0 #DA202A;}</style>');
                $('head').append('<style>.rmgheader .menu-primary-menu .primary-nav__menu-item--active-trail:before{box-shadow:0 25px 0 0 #DA202A!important;}</style>');
                $('head').append('<style>.rmgheader .menu-primary-menu .primary-nav__menu-item--active-trail a.is-active:before{box-shadow:none;}</style>');
              }
            );

            $( ".menu li.parent-item-2" ).hover(function() {
                $('.mobtab-2 .menu-caret').addClass( "icon-up-arrow" );
                $('.mobtab-2 .menu-caret').removeClass( "icon-down-arrow " );
                $('head').append('<style>.rmgheader .menu li a.is-active:before{box-shadow:none;}</style>');
                $('head').append('<style>.rmgheader .menu-primary-menu .primary-nav__menu-item--active-trail:before{box-shadow:none!important;}</style>');
              }, function() {
                $('.mobtab-2 .menu-caret').removeClass( "icon-up-arrow " );
                $('.mobtab-2 .menu-caret').addClass( "icon-down-arrow " );
                $('head').append('<style>.rmgheader .menu li a.is-active:before{box-shadow:0 25px 0 0 #DA202A;}</style>');
                $('head').append('<style>.rmgheader .menu-primary-menu .primary-nav__menu-item--active-trail:before{box-shadow:0 25px 0 0 #DA202A!important;}</style>');
                $('head').append('<style>.rmgheader .menu-primary-menu .primary-nav__menu-item--active-trail a.is-active:before{box-shadow:none;}</style>');
              }
            );

            $( ".menu li.parent-item-3" ).hover(function() {
                $('.mobtab-3 .menu-caret').addClass( "icon-up-arrow" );
                $('.mobtab-3 .menu-caret').removeClass( "icon-down-arrow " );
                $('head').append('<style>.rmgheader .menu li a.is-active:before{box-shadow:none;}</style>');
                $('head').append('<style>.rmgheader .menu-primary-menu .primary-nav__menu-item--active-trail:before{box-shadow:none!important;}</style>');
              }, function() {
                $('.mobtab-3 .menu-caret').removeClass( "icon-up-arrow " );
                $('.mobtab-3 .menu-caret').addClass( "icon-down-arrow " );
                $('head').append('<style>.rmgheader .menu li a.is-active:before{box-shadow:0 25px 0 0 #DA202A;}</style>');
                $('head').append('<style>.rmgheader .menu-primary-menu .primary-nav__menu-item--active-trail:before{box-shadow:0 25px 0 0 #DA202A!important;}</style>');
                $('head').append('<style>.rmgheader .menu-primary-menu .primary-nav__menu-item--active-trail a.is-active:before{box-shadow:none;}</style>');
              }
            );
          }

          if (!Modernizr.touchevents) {

            $('.menu.accordion-menu-wrapper').on('focusout', function () {
              var $menu_container = $(this);
              setTimeout(function () {
                if ($menu_container.find(':focus').length === 0) {
                  $('.overlaymenu').hide();
                }
              }, 10);
            });

            $('.primary-menu-level-0.accordion-content-wrapper').on('focusout', function () {

              var $menu = $(this);
              // Set a short timeout as no element has immediate focus on
              // 'focusout'.
              setTimeout(function () {
                if ($menu.find(':focus').length === 0) {
                  // No link within this menu has focus so collapse the menu.
                  $menu.find('.menu-wrapper').slideUp('fast');
                }
              }, 10);
            });

            $primary_menu_links.hoverIntent({
              over: rmlcwrSlideDown,
              out: rmlcwrSlideUp
            }).focus(rmlcwrSlideDown);
          }
          else {
            // Handle touch device behaviours.
            $primary_menu_links.on('touchstart', function (event) {
              // Prevent the link routing on initial tap.
              event.preventDefault();

              var $this = $(this);
              rmlcwrSlideUp(event);
              $this.closest('.accordion-content-wrapper').find('.menu-wrapper').slideDown('fast');
              $('.overlaymenu').show();
              $("main" , "footer").css("z-index", "-2");
              if ($(window).width() >= 1440) {
                $('.menu-dropdown-desktop-lines-image').show();
              }

              $primary_menu_links.not($this).removeClass('dropped');
              if ($this.hasClass('dropped')) {
                // Menu is already opened, assume the user wants to click the
                // link.
                window.location = $this.attr('href');
              }

              $this.addClass('dropped');
            });

            // Close the menu when tapped outside of the menu wrapper.
            $('html').on('touchstart', function (event) {
              rmlcwrSlideUp(event);
              $primary_menu_links.removeClass('dropped');
              $('.overlaymenu').hide();
              $("main" , "footer").css("z-index", "unset");
              if ($(window).width() >= 1440) {
                $('.menu-dropdown-desktop-lines-image').hide();
              }
            });

            // Don't close the menu if the user has tapped inside the menu wrapper.
            $('.block-primary-nav').on('touchstart', function (event) {
              event.stopPropagation();
            });
          }

          // Position the megamenu when scrolling.
          $(window).scroll(function (event) {
            var scroll = $(window).scrollTop();
            var diff = scroll - (scroll * 2);

            var rmgheaderHeight = 0;
            var headerHeight = 0;
            var preHeaderHeight = 0;
            var navbarHeight = 0;
            var secnavHeight = 0;

            var $rmgheader = $('.rmgheader');
            if ($rmgheader.length) {
              rmgheaderHeight = $rmgheader.outerHeight();
            }

            var $header = $('.header');
            if ($header.length) {
              headerHeight = $header.outerHeight();
            }

            var $preHeader = $('.pre-header');
            if ($preHeader.length) {
              preHeaderHeight = $preHeader.outerHeight();
            }

            var $rmgsecheader = $('.secondary-menu-background');
            if ($rmgsecheader.length) {
              secnavHeight = $rmgsecheader.outerHeight();
            }

            // If the menu is in the navbar, include its height in the calculation.
            if ($('.menu-primary-menu').closest('.navbar').length) {
              var $navbar = $('.navbar');
              if ($navbar.length) {
                var navbarHeight = 0;
                navbarHeight = $navbar.outerHeight();
              }
            }

            var offset = headerHeight + preHeaderHeight + navbarHeight + rmgheaderHeight;


            if ($('.toolbar-bar').is(':visible')) {
              offset += $('.toolbar-bar').outerHeight();
            }

            if ($('.toolbar-tray').hasClass('is-active')) {
              offset += $('.toolbar-tray').outerHeight();
            }

            $('.secondary-rmg-container .accordion-content-wrapper').find('.menu-wrapper').css('top', + (diff + offset) + 'px');
            $('.secondary-rmg-container  .rml-bing-search').css('top', + (diff + offset + secnavHeight) + 'px');

            $('.menu-wrapper').slideUp('fast');
            $('.overlaymenu').hide();
            $("main" , "footer").css("z-index", "unset");
            if ($(window).width() >= 1440) {
              $('.menu-dropdown-desktop-lines-image').hide();
            }

            $( '.menu li div.mobtab-1 a' ).addClass( "menu-caret icon-down-arrow");
            $( '.menu li div.mobtab-2 a' ).addClass( "menu-caret icon-down-arrow");
            $( '.menu li div.mobtab-3 a' ).addClass( "menu-caret icon-down-arrow");

          });
        }
      }

        updateMenu();
        setTimeout(function() {

        // Show different menu times for desktop and mobile/tablet.
        $('.menu-primary-menu .primary-menu-child-wrapper .accordion-toggle, .secondary-menu-background .secondary-accordion-wrapper .secondary-accordion-toggle').each(function() {
          var anchorText = $(this).find('a').text();
          var separatorIndex = anchorText.indexOf('|');
          if (separatorIndex !== -1) {
            var separator = "|";
            var parts = anchorText.match(new RegExp("[^" + separator + "]+", "g"));
            if ($(window).width() < 1200) {
              var anchorTextValue = parts[1];
              var wordToRemove = "(Mobile/Tablet)";
            }
            else{
              var anchorTextValue = parts[0];
              var wordToRemove = "(Desktop)";
            }
            var device_specific_menu_label = anchorTextValue.replace(new RegExp('\\b' + wordToRemove + '\\b', 'g'), '').trim();
            device_specific_menu_label = device_specific_menu_label.replace(/\([^()]*\)/g, '').trim(); // remove parenthisis.
            $(this).find('a').text(device_specific_menu_label);
          }
        });

        }, 0);

      // Adding class to parent li from menu attributes.
      $('.menu-links-introstyle').parent().addClass('list-item-intro');
      $('.menu-links-overarchingstyle').parent().addClass('list-item-overarching');
      $('.menu-links-arrowstyle').parent().addClass('list-item-arrow');
    }
  };

  /* localStorage: A built-in web API that allows you to store data in the browser.
    The data is persistent across browser sessions, meaning it remains even after the browser is closed and reopened.
    getItem Method: This method of localStorage takes a key (in this case, 'hasReloadedBelow1200')
    and returns the value associated with that key as a string. If the key does not exist in localStorage,
    it returns null. */
  if (!localStorage.getItem('hasReloadedBelow1200')) {
    localStorage.setItem('hasReloadedBelow1200', 'false');
  }

  if (!localStorage.getItem('hasReloadedAbove1200')) {
    localStorage.setItem('hasReloadedAbove1200', 'false');
  }

  // Initialize variables to keep track of resize debounce
  let resizeTimeout;

  // Delay attaching the resize listener by 2 seconds
  setTimeout(() => {
    // this event is needed when we move from desktop i.e 1200 and less resolution
    // and again when we move to 1200 or above resolution
    window.addEventListener('resize', () => {
      // Clear the previous timeout to debounce the resize event
      clearTimeout(resizeTimeout);

      // Set a new timeout to debounce the resize event
      resizeTimeout = setTimeout(() => {
        const width = $(window).width();

        if (localStorage.getItem('hasReloadedBelow1200') === 'false' && width < 1200) {
          localStorage.setItem('hasReloadedBelow1200', 'true');
          localStorage.setItem('hasReloadedAbove1200', 'false'); // reset the above 1200 flag
          location.reload(true);
        } else if (localStorage.getItem('hasReloadedAbove1200') === 'false' && width >= 1200) {
          localStorage.setItem('hasReloadedAbove1200', 'true');
          localStorage.setItem('hasReloadedBelow1200', 'false'); // reset the below 1200 flag
          location.reload(true);
        }
      }, 1000);
    });
  }, 2000); // 2-second delay before attaching resize listener

  /**
   * Add an icon and message for links that open in a new window.
   */
  Drupal.behaviors.rmlcwrExtLink = {
    attach: function (context) {
      Drupal.rmlcwrCustom.rmlcwrExtLinkIcon(context);

      // Add an icon for Track and track links that open in a new window.
      $('#rml_track_and_trace').bind('DOMSubtreeModified', function () {
        Drupal.rmlcwrCustom.rmlcwrExtLinkIcon($('#rml_track_and_trace'));
      });

      // Adding icon for Tracked return link that open in a new window.
      $('#rml_tracked_return').bind('DOMSubtreeModified', function () {
        Drupal.rmlcwrCustom.rmlcwrExtLinkIcon($('#rml_tracked_return'));
      });
    }
  };

  /**
   * Add a file icon to download links.
   */
  Drupal.behaviors.rmlcwrFileIcon = {
    attach: function (context) {
      const downloadIcon = '<svg xmlns:xlink="http://www.w3.org/1999/xlink" focusable="false" class="icon icon--download"><use xlink:href="#download"></svg>';
      $('.file-link.content-cta-primary, .file-link.content-cta-secondary', context).once().each(function () {
        $(this).append(downloadIcon);
      });
    }
  };

  /**
   * Display new window link icon for the links pointing to external website.
   */
  Drupal.rmlcwrCustom.rmlcwrExtLinkIcon = function (context) {
    const newWindowText = '<span class="visually-hidden">' +
      Drupal.t("Opens in a new window") + '</span>';
    const newWindowIndicator =
      '<svg xmlns:xlink="http://www.w3.org/1999/xlink" focusable="false" class="new-window"><use xlink:href="#external"></svg>';

    $("a, .external-window", context).each(function () {
      const $link = $(this);
      // Check if the link opens in a new window, ignore any 'addtoany' links.
      if (($link.attr("target") === "_blank" || $link.hasClass('external-window'))
        && !rmlcwrIsAddToAny($link)
        && !$link.hasClass('ext-link-wrapped-last-word')
        && !$link.hasClass('ext-link-wrapped')) {
        var linkText = $link.text().split(' ');

        // Store the last word from the link.
        var lastWord = linkText.pop();

        // Its possible the last word is actually an icon, so ignore those
        // scenarios here, as well as ignoring links that are only a single
        // word.
        if (lastWord.length > 0 && linkText.length > 0) {
          lastWord = lastWord + newWindowText;

          // Don't add icons if the link already has an icon.
          if (!$link.closest("nav").hasClass("royalmail-social-links")) {
            lastWord = lastWord + newWindowIndicator;
          }

          // Recompile the link wrapping the final word in a span to ensure
          // the text and ext icon sit on the same line.
          var finalText = linkText.join(" ") + ' <span class="ext-link-last-word">' + lastWord + '</span>';

          if (!$link.hasClass('ext-link-wrapped-last-word')) {
            $link.addClass('ext-link-wrapped-last-word').html(finalText);
          }

        }
        else {
          //  No need of adding Open in new window text manually so removing.
          //  $link.append(newWindowText);
          $link.addClass('ext-link-wrapped');
          // Don't add icons if the link already has an icon.
          if (!$link.closest("nav").hasClass("royalmail-social-links")) {
            $link.append(newWindowIndicator);
          }
        }
      }
    });
  };

  /**
   * Slides down the menu in the header navigation.
   *
   * @param object event
   *   The hover In event.
   */

  function rmlcwrSlideDown(event) {
    // Slide up all menus, and remove all menu classes.
    event.preventDefault();
    $(this).closest(' .accordion-content-wrapper').find('.menu-wrapper').slideDown('fast');

      // Show the overlay
      $('.overlaymenu').show();
      $("main" , "footer").css("z-index", "-2");
      $('.menu-item-icon-search .open').removeClass('visually-hidden');
      $('.menu-item-icon-search .close').addClass('visually-hidden');
      $('.block-rml-bing-search').addClass('visually-hidden');
      $('#overlayrmgmenusearch').css('display', 'none');
      $('article').css({'z-index':'unset' , 'position':'unset'});
      $("main .layout-content").css("z-index", "unset");
      $("main .layout-content .block-local-tasks-block ul").css('margin-top', '18px');
      $("main .layout-content .royalmailmyaccountpageheaderparent").css('z-index', 'unset');
      $("footer").css("z-index", "unset");
      $(".content-bottom-wrapper").css("z-index", "unset");
      $('.bingsearchresults').css('z-index', 'unset');
      $('.rmgheader').css('box-shadow', '');

      if ($(window).width() >= 1440) {
        $('.menu-dropdown-desktop-lines-image').show();
      }
  };

  /**
   * Determines if a link is from AddToAny.
   *
   * @param object $link
   *   The link.
   *
   * @return bool
   *   true if the link is from AddToAny, false otherwise.
   */
  function rmlcwrIsAddToAny($link) {
    if ($link.parent().hasClass('a2a_full_footer') || $link.parent().hasClass('a2a_kit') || $link.hasClass('a2a_i')) {
      return true;
    }

    return false;
  };

  /**
   * Slides up the menu in the header navigation.
   *
   * @param object event
   *   The hover Out event.
   */
  function rmlcwrSlideUp(event) {
    var $menu_attach_wrapper = $('.menu-wrapper');

    // When hovering off, slide up the menus remove styling classes.
    if ($(".menu-wrapper:hover").length === 0) {
      $menu_attach_wrapper.slideUp('fast');
      $('.overlaymenu').hide();
      $("main" , "footer").css("z-index", "unset");
      if ($(window).width() >= 1440) {
        $('.menu-dropdown-desktop-lines-image').hide();
      }
    }

    // Collapse menu items that don't collapse on menu drop down hoverout.
    $menu_attach_wrapper.mouseleave(function (event) {
      $menu_attach_wrapper.slideUp('fast');
      $('.overlaymenu').hide();
      $("main" , "footer").css("z-index", "unset");
      if ($(window).width() >= 1440) {
        $('.menu-dropdown-desktop-lines-image').hide();
      }
    });
  };

  /**
   * Add clear button when value is entered in track item field.
   *
   * @type {Drupal~behavior}
   *
   * @prop {Drupal~behaviorAttach} attach
   */
  Drupal.behaviors.trackItemClear = {
    attach: function (context) {
      var $trackInput = $('.form-item-track-number .form-text:text');
      var $iconCloseBtn = $('.form-item-track-number .field-suffix > div');

      $trackInput.keyup(function (e) {
        if ($(this).val() != '') {
          $trackInput.not(this).attr('disabled','disabled');
          $iconCloseBtn.removeClass('visually-hidden');
        }
        else {
          $trackInput.removeAttr('disabled');
          $iconCloseBtn.addClass('visually-hidden');
        }

        $iconCloseBtn.click(function () {
          $trackInput.val('');
          $iconCloseBtn.addClass('visually-hidden');
        });
      });
    }
  };

  /**
   * Set a select element selected state.
   *
   * @type {Drupal~behavior}
   *
   * @prop {Drupal~behaviorAttach} attach
   */
  Drupal.behaviors.selectState = {
    attach: function (context) {
      $('select').change(function () {
        var $this = $(this);

        if ($this.val()) {
          $this.addClass('selected');
        }
        else {
          $this.removeClass('selected');
        }
      });
    }
  };

  /**
   * Bind ajax to links that use the 'call-ajax' class.
   *
   * @param {HTMLElement} element
   *   Element to enable Ajax functionality for.
   */
  Drupal.rmlcwrCustom.callAjaxOnLinks = function (element) {
    // Bind Ajax behaviors to all items showing the class 'call-ajax'.
    $(element)
      .find('.call-ajax')
      .once('ajax')
      .each(function (i, ajaxLink) {
        const $linkElement = $(ajaxLink);

        const elementSettings = {
          progress: { type: 'throbber' },
          speed: 'fast',
          dialogType: $linkElement.data('dialog-type'),
          dialog: $linkElement.data('dialog-options'),
          dialogRenderer: $linkElement.data('dialog-renderer'),
          base: $linkElement.attr('id'),
          element: ajaxLink,
        };
        const href = $linkElement.attr('href');
        // For anchor tags, these will go to the target of the anchor rather
        // than the usual location.
        if (href) {
          elementSettings.url = href;
          elementSettings.event = 'click';
        }
        Drupal.ajax(elementSettings);
      });
  };

  /**
   * Add play button behaviour to video overlays.
   */
  Drupal.behaviors.rmlcwrVideo = {
    attach: function (context) {

      $('button.video-play').once('rmlcwrVideo').click(function () {

        // Hide the play button.
        var $playButton = $(this).parent();
        $playButton.hide();

        // Hide the overlay.
        $playButton.siblings('.video-thumbnail').hide();

        // Play the video from the nested iframe.
        $playButton.siblings('.field--name-field-video').find('iframe').contents().find('iframe')[0].src += "&autoplay=1";
      });
    }
  };

   /**
   * Add js for functional hero free collection tag
   */
  Drupal.behaviors.freeTag = {
    attach: function (context) {
      $('.dropdown-item.select-dropdown-option').on('click', function() {
        $('.free-collection-label').hide();
        $('.free-collection-btn-select').removeClass('free-collection-btn-select');

        var selectedOption = $(this).text();
        var button = $(this).closest('.select-options').find('#parceltype');
        button.text(selectedOption);
        button.addClass('button-dropdown-select');
      });
    }
  }

  /**
   * Add js for secondary Menu
   */
  Drupal.behaviors.secondaryNavOperation = {
    attach: function (context) {

      function loadData() {
        setTimeout(function() {
          $('.secondary-menu-container .secondary-menu-background nav').removeClass('secnavhidden');
        }, 150); // Time in milliseconds, e.g., 1000ms = 1 second

        $('.secondary-menu-container .secondary-menu-block .secondary-child-menu .secondary-child-menu-wrapper a.is-active').hover(
          function() {
            $(this).css({'text-decoration': 'unset' , 'color': '#2A2A2D'});
          }
        );

        // Check if the URL contains '?check_logged_in=1'
        if (window.location.href.indexOf('?check_logged_in=1') > -1) {
          $('.secondary-menu-background').parents('.rmg-container').find('.block-local-tasks-block').css('margin-top', '72px');
        }

        // Call adjustNavItems after loadData operations complete
        setTimeout(function() {
          adjustNavItems();
        }, 170);

        // Call adjustNavItems on window resize
        $(window).resize(function() {
          setTimeout(function() {
            adjustNavItems();
          }, 110);
        });
      }

      function adjustNavItems() {
        var $navContainer = $('.secondary-child-menu-wrapper');

        // Function to release items from dropdown to the main navigation
        function releaseItemsFromDropdown() {
          $('.more-dropdown a').each(function(index, element) {
            $navContainer.append(element);
          });
          $('.more-button').remove();
        }

        if ($navContainer.length > 0) {
          if ($(window).width()>=1200) {
            $navContainer.each(function(index, nav) {
              var $nav = $(nav);
              var navWidth = $nav.width();
              var $child = $nav.children();

              var anchorTagsWidth = 0;
              var anchorTagsToMove = [];
              var maxMoreElementWidth = 0;

              var prevElement = null;
              $child.each(function(index, element) {
                var tagName = element.tagName;
                if (tagName === 'A') {
                  anchorTagsWidth += element.offsetWidth;
                  if (anchorTagsWidth > navWidth) {
                    // Only push prevElement and current element to anchorTagsToMove
                    if (prevElement !== null) {
                      anchorTagsToMove.push(prevElement);
                    }
                    anchorTagsToMove.push(element);
                  }

                  if (element.offsetWidth > maxMoreElementWidth) {
                    maxMoreElementWidth = element.offsetWidth;
                  }

                  prevElement = element;
                }
              });

              if (anchorTagsToMove.length > 0) {
                var moreButton = $('<div class="more-button"><span class="more-custom-text">More</span><span class="icon-down-arrow-more more-custom-icon"></span></div>');
                var moreDropdown = $('<div class="more-dropdown"></div>');
                moreButton.append(moreDropdown);
                $nav.append(moreButton);

                // Set width of moreDropdown to maxMoreElementWidth
                moreDropdown.css('width', maxMoreElementWidth + 'px');

                // Move elements to dropdown
                for (var j = 0; j < anchorTagsToMove.length; j++) {
                  moreDropdown.append(anchorTagsToMove[j]);
                }

                moreButton.on('mouseenter', function() {
                  moreDropdown.stop(true, true).slideDown();
                });
                moreButton.on('mouseleave', function() {
                  moreDropdown.stop(true, true).slideUp(10);
                });

                moreButton.hover(
                  function() {
                    $(this).addClass('more-button-bg');
                    $('.more-custom-icon').toggleClass('icon-up-arrow-more icon-down-arrow-more');
                  },
                  function() {
                    $(this).removeClass('more-button-bg');
                    $('.more-custom-icon').toggleClass('icon-up-arrow-more icon-down-arrow-more');
                  }
                );
              }
            });
          } else {
            // If window width is 1200px or less, release items from dropdown
            releaseItemsFromDropdown();
          }
        }
      }

      function Adjustmenu() {
        if(jQuery(window).width()>=1200){
          $('.parent-item-1').css('display', 'inline-block');
          $('.parent-item-2').css('display', 'inline-block');
          $('.parent-item-3').css('display', 'inline-block');
          $('.overlaymenu').hide();
          $('.menu-primary-menu .mobile-tablet-device').css('display', 'none');
          $('.rmgheader .menu-primary-menu .mobile-tablet-lines-image').css('display', 'none');
          $('.secondary-accordion-content').css('display', 'block');
        }
        if(jQuery(window).width()<=1199){
          $('.secondary-accordion-content').css('display', 'none');
        }
      }

      jQuery(window).resize(function() {
        Adjustmenu();
      });

      var specificAlias = '/services-near-you#/';
      var currentUrl = window.location.href;
      if (currentUrl.indexOf(specificAlias) !== -1) {
        $('.sitebranding-2 .parent-menu-name').addClass('no-underline');
      }

      $('.rmgheader').parents('div').addClass('rmg-container');
      $('.rmgheader .secondary-menu-background').parents('.rmg-container').addClass('secondary-rmg-container');
      $('.rmgheader .header-content .secondary-menu-background').remove();
      $('.secondary-menu-container').appendTo('header');
      $('#block-loginandregister-mobile').find('svg').addClass('icon--person');
      $('#block-loginandregister-mobile').find('svg').removeClass('icon--account-icon');
      $('#block-loginandregister-mobile').find('use').attr('xlink:href', '#person');
      $('#block-useraccount-mobile').find('svg').addClass('icon--person');
      $('#block-useraccount-mobile').find('svg').removeClass('icon--account-icon');
      $('#block-useraccount-mobile').find('use').attr('xlink:href', '#person');
      $('#block-useraccountmenu').find('svg').removeClass('icon--account-icon');
      $('#block-useraccountmenu').find('use').attr('xlink:href', '#person');

      loadData();

      $(document).on('click', '.link-button', function() {
        $('.reactapps .app-main-content .pattern .section-row').css('z-index', '1');
        $('.toolbar-oriented').css({'position': 'relative' , 'z-index' : '1'});
      });

      $(document).on('click', '.close-button', function() {
        $('.reactapps .app-main-content .pattern .section-row').css('z-index', '1');
        $('.toolbar-oriented').css({'position': '' , 'z-index' : ''});
      });

      $(document).on('click', function(event) {
        var modal = $('.redelivery-main-content .modal');
        var modalContent = $('.redelivery-main-content .modal-content');
        if (!modalContent.is(event.target) && modalContent.has(event.target).length === 0) {
            modal.hide();

            $('.reactapps .redelivery-main-content .pattern .section-row').css('z-index', '1');
            $('.toolbar-oriented').css({'position': '' , 'z-index' : ''});
        }
      });

      // get a quote sticky script
      var $getAQuoteSection = $('.get-a-quote-btn-section');
      if (!$getAQuoteSection.length) {
        return;
      }
      var targetOffset = $getAQuoteSection.offset().top;
      var popup = $('.get-a-quote-sticky-section');
      var secondaryNav = $('.secondary-menu-background');
      $(window).scroll(function() {
        if ($(window).scrollTop() >= targetOffset) {
          if($("body").hasClass('toolbar-horizontal') || $("body").hasClass('toolbar-vertical')) {
            if($("body").hasClass('toolbar-horizontal') && $("body").hasClass('toolbar-tray-open'))
              popup.css('top', '79px');
            else {
              popup.css('top', '39px');
            }
          } else {
            popup.css('top', '0px');
          }
          popup.show();
          secondaryNav.hide();
        } else {
          popup.hide();
          secondaryNav.show();
        }
      });

      $( ".menu li a" ).hover(
        function() {
          $( this ).addClass( "hover" );
          $( this ).removeClass( "&::after" );
        }, function() {
          $( this ).removeClass( "hover" );
          $( this ).addClass( "&::after" );
        }
      );
    }
  }

  /**
