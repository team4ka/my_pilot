            $('.menu-primary-menu .primary-menu-child-wrapper .accordion-content').not($(this).next('.menu-primary-menu .primary-menu-child-wrapper .accordion-content')).slideUp();
          });
        }
        else {
          $('.menu-item-icon-search .open').once().click(function (e) {
            $('article').css({'z-index':'-2' , 'position':'relative'});
            $("main .layout-content").css("z-index", "-2");
            $("main .layout-content:first").css("z-index", "unset");
            $("main .layout-content .block-local-tasks-block ul").css('margin-top', '0px');
            $("main .layout-content .royalmailmyaccountpageheaderparent").css('z-index', '-2');
            $("footer").css("z-index", "-2");
            $(".content-bottom-wrapper").css("z-index", "-2");
            $('.bingsearchresults').css('z-index', '-2');
            $('#overlayrmgmenusearch').css('display', 'block');
            $('.rmgheader').css('box-shadow', 'none');

            $(window).scroll(function (event) {
              $('.menu-item-icon-search .open').removeClass('visually-hidden');
              $('.menu-item-icon-search .close').addClass('visually-hidden');
              $('.block-rml-bing-search').addClass('visually-hidden');
              $("main .layout-content").css("z-index", "unset");
              $("main .layout-content .block-local-tasks-block ul").css('margin-top', '18px');
              $("main .layout-content .royalmailmyaccountpageheaderparent").css('z-index', 'unset');
              $("footer").css("z-index", "unset");
