/* global a2a*/
(function (Drupal) {
  'use strict';

  Drupal.behaviors.addToAny = {
    attach: function (context, settings) {
      // If not the full document (it's probably AJAX), and window.a2a exists
      if (context !== document && window.a2a) {
        a2a.init_all(); // Init all uninitiated AddToAny instances
      }
    }
  };

})(Drupal);
;
/**
 * @file
 */

(function ($, Drupal) {
  Drupal.rmlTealiumIq = {};

  /**
   * Get form errors and pass them to Tealium.
   *
   * @param {string} pageName Tealium tag pageName value.
   * @param {string} pageApplicationStep Tealium tag pageApplicationStep value.
   * @param {string} errorElement Selector for the HTML error element.
   * @param {string} pageErrorType Tealium pageErrorType value.
   */
  Drupal.rmlTealiumIq.setTealiumErrors = function (pageName, pageApplicationStep, errorElement = 'label.error', pageErrorType = 'Field Validation') {
    // Get all the field error messages.
    let errorMessage = [];
    $(errorElement).each(function () {
      if (this.innerText) {
        errorMessage.push(this.innerText);
      }
    });

    if (errorMessage.length > 0) {
      // Set the Tealium tags for error message on the form.
      utag.view({
        'pageName' : pageName + ' Error',
        'pageApplicationStep' : pageApplicationStep + ' Error',
        'pageErrorMessage' : errorMessage.join("|"),
        'pageErrorType' : pageErrorType
      });
    }
  };

  /**
   * Make a utag.link call.
   *
   * @see https://docs.tealium.com/platforms/javascript/api/tracking-functions/#utag-link
   *
   * @param object data
   *   An object of key:value properties to pass to utag.link Tealium call.
   */
  Drupal.rmlTealiumIq.utagLink = function (data) {
    if (typeof data === 'undefined') {
      return;
    }
    if (typeof utag.link !== 'undefined') {
      utag.link(data);
    }
  };

})(jQuery, Drupal);
;
