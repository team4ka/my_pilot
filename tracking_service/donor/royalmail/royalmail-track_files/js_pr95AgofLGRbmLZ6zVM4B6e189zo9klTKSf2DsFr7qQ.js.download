    $('.block-inner-wrapper .ui-tabs-nav .ui-tabs-tab li').hover(
      function() {
        $( this ).addClass( "ui-state-hover" );
      }, function() {
        $( this ).removeClass( "ui-state-hover" );
      }
    );
  } );

  /**
   * Adding js for Business Hero Component
   * when CTA Strip is added.
   */
  Drupal.behaviors.businessHeroCTAStrip = {
    attach: function (context) {
      $('.paragraph-cta-strip-wrapper', context).each(function () {
        // Check if the paragraph-cta-strip-wrapper exists
        if ($(this).length) {
          $(this).parents('.business-hero-wrapper').find('.login-register-buttons').hide();
          $(this).parents('.business-hero-wrapper').addClass('business-hero-cta-strip');
          $(this).parents('.business-hero-wrapper').find('.v2-functional-text').addClass('col-md-6');
          $(this).parents('.business-hero-wrapper').find('.business-hero-img').addClass('col-md-6');
          $(this).parents('.logged-in-user').find('.functional-hero-links').hide();
        }
      });
    }
  };

  /**
   * js for Dual Navigation Menu
   */
  Drupal.behaviors.dualNavOperation = {
    attach: function (context) {
      // Add dual-header-container class to the main div
      $('.dualheader', context).parents('div').addClass('dual-header-container');

      const listItems = document.querySelectorAll('.dualheader .mobtab-content3 li');

      let firstHalf, secondHalf;

      if (listItems.length <= 10) {
          firstHalf = Array.from(listItems).slice(0, 5);
          secondHalf = Array.from(listItems).slice(5);
      } else {
          firstHalf = Array.from(listItems).slice(0, Math.ceil(listItems.length / 2));
          secondHalf = Array.from(listItems).slice(Math.ceil(listItems.length / 2));
      }

      // Create two new <ul> elements
      const firstColumn = document.createElement('ul');
      firstColumn.classList.add('column');

      const secondColumn = document.createElement('ul');
      secondColumn.classList.add('column');

      // Append the first 5 items to the first column and next 5 items to the second column
      firstHalf.forEach(item => firstColumn.appendChild(item));
      secondHalf.forEach(item => secondColumn.appendChild(item));

      // Remove the original list
      const removeElement = document.querySelector('.dualheader .mobtab-content3 ul');
      if (removeElement) {
        removeElement.remove();
      }

      const elementExist = document.querySelector('.dualheader .mobtab-content3');

      if (elementExist) {
        // Append the two new columns to the container
        elementExist.appendChild(firstColumn);
        elementExist.appendChild(secondColumn);
      }

      const columns = document.querySelectorAll('.dualheader .mobtab-content3 .column');

      columns.forEach(column => {
        // Check if the div is empty
        if (!column.innerHTML.trim()) {
          // Set the display to none
          column.style.display = 'none';
        }
      });

      $('.dualmenuhamburger', context).on('click', function(event) {
        event.preventDefault();
        $(this).hide(); // Hide the hamburger menu
        $('.dualmenuclose', context).css('display', 'flex'); // Show the close button
        $('#dual-navigation', context).addClass('visible'); // Show the navigation menu
        $('.dualmenuclosemob').show();
        $('.overlaydualmenu').show();
      });

      $('.dualmenuclose', context).on('click', function(event) {
        event.preventDefault();
        $(this).hide(); // Hide the close button
        $('.dualmenuhamburger', context).css('display', 'flex'); // Show the hamburger menu
        $('#dual-navigation', context).removeClass('visible'); // Hide the navigation menu
        $('.overlaydualmenu').hide();
      });

      $('.dualmenuclosemob', context).on('click', function(event) {
        event.preventDefault();
        $(this).hide(); // Hide the close button
        $('.dualmenuhamburger', context).css('display', 'flex'); // Show the hamburger menu
        $('#dual-navigation', context).removeClass('visible'); // Hide the navigation menu
        $('.dualmenuclose').hide();
        $('.overlaydualmenu').hide();
      });

      if ($(window).width() < 1200) {
        $('.dualmenuhamburger').on('click', function(e ) {
          e.preventDefault();
          $('body').addClass('dual-menu-visible');
        });

        $('.dualmenuclosemob', context).on('click', function(event) {
          $('body').removeClass('dual-menu-visible');
          $('.mobtab-1').addClass('accordion-toggle accordion-mobile-only open');
          $('.mobtab-1 a').attr({href: "/"});
          $('.mobtab-2').addClass('accordion-toggle accordion-mobile-only open');
          $('.mobtab-2 a').attr({href: "/"});
          $('.mobtab-3').addClass('accordion-toggle accordion-mobile-only open');
          $('.mobtab-3 a').attr({href: "/"});
          $('.back-button').hide();
          $('.parent-item-3').css('display', 'block');
          $('.parent-item-2').css('display', 'block');
          $('.parent-item-1').css('display', 'block');
          $('li:last-child .primary-menu-level-0').css('display', 'block');
          $('.dualheader .menu-primary-menu .dual-primary-menu-level-0 .icon').css('display', 'block');
          $('.dualheader .menu-primary-menu .mobile-tablet-device').css('display', 'block');
          $('.menu-primary-menu .accordion-content').slideUp('slow');
          $('.menu-primary-menu .accordion-toggle').removeClass('open').attr('aria-expanded', 'false');
          $('.dual-primary-menu-level-0').removeClass('dualmenumob-open');
          $('.dualheader .dual-tool-wrapper').css('display', 'block');
        });
      }
      else {
        // for screen size greater than 1200

        // removing the li when mobile-tablet-home class is there
        $('a.mobile-tablet-home').closest('li.dual-primary-menu-level-1').hide();

        $('.dualmenuhamburger', context).on('click', function(event) {
          $('.dual-header-menu', context).css('display', 'block');
        });
        $('.dualmenuclose', context).on('click', function(event) {
          $('.dual-header-menu', context).css('display', 'none');
        });
      }
    }
  };

  /**
   * js for Dual and Rml Footer
  */
  Drupal.behaviors.dualFooterOperation = {
    attach: function (context) {
      // Add dual-footer-breadcrumbs class when it has breadcrumbs-2 as a child class.
      $('.breadcrumbs-2').parents('.content-bottom-wrapper').addClass('dual-footer-breadcrumbs');
      $('.dual-footer-logos').parents('.footer').addClass('dual-footer');
      $('.rml-footer-logos').parents('.footer').addClass('rml-footer');
      $('.dual-footer-sitelinks').parents('.post-footer').addClass('dual-post-footer');
      $('.rml-footer-sitelinks').parents('.post-footer').addClass('rml-post-footer');
      $('.sitelinkscol .new-window').parents('.dual-sitelinks').addClass('sitelinks-new-window');
      $('.sitelinkscol .new-window').parents('.rml-sitelinks').addClass('sitelinks-new-window');
      $('.menulinkcol .new-window').parents('.menulinkcol a').addClass('sitelinks-new-window');

      // Trim (Text) string and get the remaning string when it has class as visible-text
      $('.dual-footer-partner-logos .visible-text,  .rml-footer-partner-logos .visible-text').each(function() {
        var anchorTextValue = $(this).text();
        var wordToRemove = "(Text)";
        var regex = new RegExp("\\b" + wordToRemove + "\\b", "gi");
        if (anchorTextValue.match(regex)) {
          var logo_text_menu = anchorTextValue.replace(new RegExp('\\b' + wordToRemove + '\\b', 'g'), '').trim();
          logo_text_menu = logo_text_menu.replace(/\([^()]*\)/g, '').trim(); // remove parenthisis.
          $(this).text(logo_text_menu);
        }
      });
    }
  };

  /**
   * js for Modals Fix.
   */
  Drupal.behaviors.modalsFix = {
