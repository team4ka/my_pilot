ToIcon:"language-cymraeg",days:[{english:"Monday",welsh:"Dydd Llun"},{english:"Tuesday",welsh:"Dydd Mawrth"},{english:"Wednesday",welsh:"Dydd Mercher"},{english:"Thursday",welsh:"Dydd Iau"},{english:"Friday",welsh:"Dydd Gwener"},{english:"Saturday",welsh:"Dydd Sadwrn"},{english:"Sunday",welsh:"Dydd Sul"}],months:[{english:"January",welsh:"Ionawr"},{english:"February",welsh:"Chwefror"},{english:"March",welsh:"Mawrth"},{english:"April",welsh:"Ebrill"},{english:"May",welsh:"Mai"},{english:"June",welsh:"Mehefin"},{english:"July",welsh:"Gorffennaf"},{english:"August",welsh:"Awst"},{english:"September",welsh:"Medi"},{english:"October",welsh:"Hydref"},{english:"November",welsh:"Tachwedd"},{english:"December",welsh:"Rhagfyr"},{english:"Jan",welsh:"Ion"},{english:"Feb",welsh:"Chwef"},{english:"Mar",welsh:"Maw"},{english:"Apr",welsh:"Ebr"},{english:"May",welsh:"Mai"},{english:"Jun",welsh:"Meh"},{english:"Jul",welsh:"Gorff"},{english:"Aug",welsh:"Awst"},{english:"Sep",welsh:"Medi"},{english:"Oct",welsh:"Hyd"},{english:"Nov",welsh:"Tach"},{english:"Dec",welsh:"Rhag"}]},edwMessage:{initialText:"We normally expect to deliver to your address between",noStartText:"We normally expect to deliver to your address by",am:"am",pm:"pm",noStartEndText:"We expect to deliver your item today",futureStartEndText:"We expect to deliver it on",between:"between",by:"by",dateFormat:"EEEE dd MMMM yyyy"},home:{searchTitle:"Track your item",continue:"Track your delivery",deleteDialog:{title:"Delete items",message:"Are you sure you want to delete these <n> tracked items?",cancel:"Cancel",delete:"Delete"},errors:{invalidTrackingNumber:"Sorry - we don't recognise that number. Please check the information to make sure your tracking code is correct.",pfwReferenceNumberUntracked:"Online tracking is not available for this Parcelforce service. The delivery speed is not guaranteed, so please check our country information pages and then confirm delivery with your recipient.",technicalError:"Sorry, there was a problem, please try again",pfw9CharacterReferenceNumber:"It is no longer possible to track based on the number you have entered. Please enter the full 14 digit tracking number for each individual parcel",tooManyRequestsErrorMessage:"Sorry, your tracking request couldn't be completed right now. We're seeing higher than usual traffic. Please try again later."},trackingNumberInput:{label:"Your reference number",placeholder:"e.g. AA123456789US",minLength:"9",maxLength:"27",emptyError:"Please enter a reference number."},notificationMessage:"",slowRequestThresholdMessage:"Please wait as we're busier than usual. This may take a few moments.",recentlyTrackedItems:{title:"Recently tracked items",loginLink:"/login?destination=/track-your-item",loginLinkText:"Log in",loginText:"to see the deliveries you've been tracking recently.",description:"A maximum of 30 items can be saved at a time. New items will automatically replace the oldest item.",noItemsText:"No recently tracked items",showMoreText:"Show more",initialItemsCount:10,showMoreItemsStep:10,refreshButtonLabel:"Refresh",deleteTheseItemsButtonLabel:"Delete these <count> items",itemTrackingErrorMessage:"Sorry, we're not able to retrieve tracking information for this item",technicalErrorMessageDelete:"We seem to have a technical problem processing your request. Please try again.",technicalErrorMessageLoad:"Sorry, there was a problem. Please refresh the page to try again.",tableHeaders:{referenceNumber:"Reference number",lastUpdated:"Last updated",status:"Status",showing:"Showing <current> of <total> items"},sortAndFilter:{buttonText:"Sort and Filter",sortDropdownLabel:"Sort",sortDropdownItems:[{id:"SB1",name:"Most recently tracked"},{id:"SB2",name:"Last updated"}],filterDropdownLabel:"Delivery status",filterDefaultValue:"All delivery statuses"}},trackingNumberHelpModal:{openButtonText:"Need help with your reference number?",header:"I need help with my reference number",content:"## Why isn’t my reference number recognised by Track your item?<br> There could be a number of reasons for this.<br> * Please check you've entered the number correctly.<br> * If you're the recipient, check the sender has given you the right reference number.<br> * Check the reference number is for an item sent with Royal Mail, using a service that offers tracking.<br> * If the item has been sent. The sender might have created a tracking number, but not yet submitted the item into our network. Please try again later.<br> * All Parcelforce customers with a 9 or 14 character consignment number, please [track your item(s) here](https://www7.parcelforce.com/track-trace).<br> * Find out more about which [services you can track](https://personal.help.royalmail.com/app/answers/detail/a_id/52).<br> ## How do I find my reference number?<br> Your number is between 9 and 27 characters long. You’ll find it on your item’s label or your Post Office® receipt. If you missed a delivery, it will be on the ‘Something for You’ card we posted through your letterbox.<br><br> It may be called a barcode or a reference.<br><br> If you’re using a Customer Collection, your manifest should list the reference numbers of items collected.<br> ## What can I do if I’ve lost my reference number?<br> If you’re the recipient:<br> * Contact the sender and ask them to give you the number<br> * If you ordered an item online, check your order confirmation or invoice. It might contain your reference number.<br><br> If you’re the sender:<br> * Try contacting the recipient. They’ll be able to tell you if they’ve received the item.<br> * We’re sorry, but if you sent your item at a Post Office® and you’ve lost the receipt or the tear-off section from the label, we won’t be able to tell you the reference number<br><br>Please note: we can’t use any other information like a name or address to track items. Unfortunately, without a reference number, you won’t be able to track your item.<br><br> ## What if I have a ‘Something for You’ card? \\n\\nIf you have missed a delivery, we will post a ‘Something for You’ card through your letterbox. We are introducing an improved card which contains a reference number in the form of a 9-digit unique ID. For help on using the ‘Something for You’ card please visit our dedicated [‘Something for You’ web page](https://www.royalmail.com/somethingforyou)."}},hmPassportOffice:{searchTitle:"Track items from HM Passport Office",continueButtonText:"Track your delivery",panNumberInput:{label:"Application reference number",placeholder:"e.g. AA123456789US",minLength:"10",maxLength:"13",emptyError:"Please enter a reference number."},postcode:{label:"Your postcode",placeholder:"",minLength:"7",maxLength:"7",emptyError:"Please enter a valid postcode."},errors:{invalidPanNumberError:"Please enter a valid Application reference number or tracking number.",invalidPostcodeError:"Please enter a valid postcode."}},passportItems:{searchTitle:"Your items from HM Passport Office",backButtonText:"Track another reference",referenceNumberlabel:"Application reference",instructions:"For the majority of passport deliveries, if you have a letterbox that allows us to post directly into your property we can deliver even if you are not at home.",tableHeading:{referenceNumber:"Reference number",type:"Type",status:"Status"},helpText:{text:"If you have any further questions or queries please visit our",hyperlinkText:"help page",hyperlink:""}},consignment:{title:"Your consignment details",backButtonText:"Track another item",referenceNumberLabel:"Consignment number",instructions:"Placeholder",tableHeading:{referenceNumber:"Reference number",lastUpdated:"Last updated",status:"Status",showingCount:"Showing {0} of {1}"},pageSizeLabel:"Items per page",pageSizes:[10,25,50],statusFilter:{title:"Select status",selected:"selected"},search:{placeholder:"Search by reference number",clearLabel:"Clear search"}},postcodeVerification:{title:"Received a Something for You card?",subtitle:"See the items from your missed delivery",barcodeIdInput:{label:"Your Unique Card ID",placeholder:"e.g. 012345678",minLength:"9",maxLength:"9",invalidFormatError:"Please enter a valid Card ID."},postcodeInput:{label:"Your delivery postcode",placeholder:"e.g. NW83QA",minLength:"7",maxLength:"7",invalidFormatError:"Please enter a valid postcode."},backButtonText:"Back",submitButtonText:"Enter"},barcodedItems:{searchTitle:"Your missed delivery items",backButtonText:"Track another item",referenceNumberlabel:"Unique Card ID",description:"Sorry, we tried to deliver your item(s) but there didn’t seem to be anyone in. Your missed deliveries are eligible for redelivery – please submit each request individually.",tableHeading:{referenceNumber:"Barcode number",customerName:"Customer name",lastUpdated:"Last updated",status:"Status",showingCount:"Showing {0} of {1}"},noResultsMessage:"No results found",viewButtonLabel:"View",pageSizeLabel:"Items per page",pageSizes:[10,25,50],statusFilter:{title:"Select status",selected:"selected",otherStatusLabel:"Other",noStatusAvailable:"No status available"},search:{placeholder:"Search by barcode number",clearLabel:"Clear search"},filterThreshold:5},trackingInformation:{trackingNumberLabel:"Tracking number:",productNameLabel:"Service used:",documentTypeLabel:"Type:",itemFromLabel:"Item from:",backButtonText:"Track another item",hmPassportItemsBackButtonText:"HM Passport items",consignmentItemBackButtonText:"Back to consignment",barcodedP739ItemBackButtonText:"Back",alternateBarcodeId:"Alternate number:",international:{destination:"Destination:",handedTo:"Handed to:",ctaLabel:"Continue tracking"},deliveryOptions:{ctaLabel:"Update delivery options",ctaUrl:"/change-delivery-option#?trackingNumber="},bookARedelivery:{ctaLabel:"Book a redelivery"},liveTracking:{ctaLabel:"View live tracking",ctaUrl:"https://wwwqs.royalmail.com/better-mile-widget/iframe?tracking_id="},trackingHistory:{title:"Tracking history",barcodedP739Title:"History"},proofOfDelivery:{title:"Proof of delivery",instructions:"Provi