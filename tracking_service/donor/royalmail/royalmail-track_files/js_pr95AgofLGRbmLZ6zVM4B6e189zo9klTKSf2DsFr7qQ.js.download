//# sourceMappingURL=main.bundle.js.map ;
/**
 * @file
 * Defines the behavior of the Track and Trace application.
 */

(function ($, Drupal, drupalSettings) {

  'use strict';

  Drupal.behaviors.rmlTrackAndTrace = {
    attach: function (context) {
      // Displaying Need help block on specific pages.

      // Bind the change in html structure event.
      // As React journey page change doesn't reload the entire page,
      // an event is require to check the changed URL in browser.
      $('#rml_track_and_trace').bind('DOMSubtreeModified', function () {
        var loc = window.location.href;

        // Get the current step name.
        var index = loc.indexOf('#/');
        // Few steps have query string parameters.
        var queryStringIndex = loc.indexOf('?');

        // Get the step name after '#' and before '?' from the URL.
        // E.g. <env>/track-your-item#/tracking-results
        // stepName will be 'tracking-results'
        var stepIndex = index + 2;
        var stepName = loc.substr(stepIndex);

        if (queryStringIndex >= 0) {
          stepName = loc.substring(stepIndex, queryStringIndex);
          // Few steps of journey has '/' before query string parameter.
          var slashIndex = stepName.indexOf('/');
          if (slashIndex >= 0) {
            stepName = stepName.substring(0,slashIndex);
          }
        }

        $('.need-help-track-and-trace').show();
        // If current step is listed, then please hide the "Need help" block.
        if ($.inArray(stepName, drupalSettings.rml_track_and_trace.steps_no_need_help_block) >= 0) {
          $('.need-help-track-and-trace').hide();
        }

      });
    }
  };

})(jQuery, Drupal, drupalSettings);
;
/**
* DO NOT EDIT THIS FILE.
* See the following change record for more information,
* https://www.drupal.org/node/2815083
* @preserve
**/
