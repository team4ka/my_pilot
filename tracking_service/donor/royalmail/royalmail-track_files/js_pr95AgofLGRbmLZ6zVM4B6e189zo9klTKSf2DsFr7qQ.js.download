            if ($(e.target).hasClass('block-primary-nav')) {
              // Collapse the menu if tapped outside of the menu.
              $('body').removeClass('menu-visible');
            }
          });
          $('.menu-primary-menu .accordion-toggle').on('click', function (e) {
            if ($(this).hasClass('open')) {
              $('.back-button').css('display', 'block');
            }
            else {
              if (!$('.menu-primary-menu .accordion-toggle').hasClass('open')) {
                $('.back-button').css('display', 'none');
                $('body.toolbar-fixed .toolbar-oriented .toolbar-bar').css('z-index', 'none');
              }
            }
          });

          $('.parent-item-1').on('click', function (e) {
              // Check if the clicked accordion item is already open
              if (!$(this).hasClass('open')) {
                // If not open, proceed with the default behavior
                $('.mobtab-1').addClass('accordion-toggle accordion-mobile-only open');
                $('.mobtab-1 a').attr({href: "/"});
                $('.mobtab-1').removeClass('accordion-toggle accordion-mobile-only open').off('click');
                $('.mobtab-1 a').removeAttr('href').off('click');
                $('.parent-item-1, .menu-primary-menu .accordion-toggle').prop('disabled', true);
                $('.back-button').css('display', 'block');
                $('.parent-item-2').css('display', 'none');
                $('.parent-item-1').css('display', 'block');
                $('.parent-item-3').css('display', 'none');
                $('li:last-child .primary-menu-level-0').css('display', 'none');
                $('.rmgheader .menu-primary-menu .primary-menu-level-0 .icon').css('display', 'none');
                $('.dualheader .menu-primary-menu .dual-primary-menu-level-0 .icon').css('display', 'none');
                $('.menu-primary-menu .mobile-tablet-device').css('display', 'none');
                $('.rmgheader .menu-primary-menu .mobile-tablet-lines-image').css('display', 'none');
                $('.parent-item-1 .mobtab-content1').css('display', 'block');
                $('.dual-primary-menu-level-0').addClass('dualmenumob-open');
                $('.dualheader .dual-tool-wrapper').css('display', 'none');

                return true;
              } else {
                // If open, prevent the default behavior (i.e., closing the accordion item)
                $('.mobtab-1').removeClass('accordion-toggle accordion-mobile-only open').off('click');
                $('.mobtab-1 a').removeAttr('href').off('click');
                $('.parent-item-1, .menu-primary-menu .accordion-toggle').prop('disabled', true);
                $('.back-button').css('display', 'block');
                $('.parent-item-2').css('display', 'none');
                $('.parent-item-1').css('display', 'block');
                $('.parent-item-3').css('display', 'none');
                $('li:last-child .primary-menu-level-0').css('display', 'none');
                $('.rmgheader .menu-primary-menu .primary-menu-level-0 .icon').css('display', 'none');
                $('.dualheader .menu-primary-menu .dual-primary-menu-level-0 .icon').css('display', 'none');
                $('.menu-primary-menu .mobile-tablet-device').css('display', 'none');
                $('.rmgheader .menu-primary-menu .mobile-tablet-lines-image').css('display', 'none');
                $('.dual-primary-menu-level-0').removeClass('dualmenumob-open');
                $('.dualheader .dual-tool-wrapper').css('display', 'none');
                e.stopPropagation();
                return false;
              }
            });

          $('.parent-item-2').on('click', function () {
